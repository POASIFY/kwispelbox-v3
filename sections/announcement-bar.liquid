{% comment %}
  sections/announcement-bar.liquid — Kwispelbox KB-v3
  Geplaatst in header-group.json, boven de header.
  Meerdere berichten via blocks; CSS marquee op mobiel,
  JS-rotatie op desktop wanneer meer dan 1 bericht.
{% endcomment %}

{%- assign message_blocks = section.blocks | where: 'type', 'message' -%}
{%- assign block_count = message_blocks | size -%}

{%- if block_count > 0 -%}
  <div
    class="announcement-bar"
    role="region"
    aria-label="Aankondigingen"
    data-announcement-bar
    data-interval="{{ section.settings.rotation_interval | times: 1000 }}"
  >

    {%- comment %} Desktop: één bericht tegelijk, roterende weergave {%- endcomment %}
    <div class="announcement-bar__desktop" aria-live="polite" aria-atomic="true">
      {%- for block in message_blocks -%}
        <div
          class="announcement-bar__item{% if forloop.first %} announcement-bar__item--active{% endif %}"
          data-announcement-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.icon != blank -%}
            <span class="announcement-bar__icon" aria-hidden="true">
              {{- block.settings.icon | inline_asset_content -}}
            </span>
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="announcement-bar__text">
              {{ block.settings.text }}
            </a>
          {%- else -%}
            <span class="announcement-bar__text">{{ block.settings.text }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}

      {%- if block_count > 1 and section.settings.show_arrows -%}
        <button class="announcement-bar__arrow announcement-bar__arrow--prev" aria-label="Vorig bericht">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M19 12H5"/><path d="m12 5-7 7 7 7"/>
          </svg>
        </button>
        <button class="announcement-bar__arrow announcement-bar__arrow--next" aria-label="Volgend bericht">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

    {%- comment %} Mobiel: CSS marquee scroll {%- endcomment %}
    <div class="announcement-bar__mobile" aria-hidden="true">
      <div class="announcement-bar__marquee">
        <div class="announcement-bar__marquee-track">
          {%- for i in (1..2) -%}
            {%- for block in message_blocks -%}
              <span class="announcement-bar__marquee-item">
                {%- if block.settings.icon != blank -%}
                  <span class="announcement-bar__icon">
                    {{- block.settings.icon | inline_asset_content -}}
                  </span>
                {%- endif -%}
                {{- block.settings.text -}}
                <span class="announcement-bar__separator" aria-hidden="true">·</span>
              </span>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
{%- endif -%}

{% stylesheet %}
.announcement-bar {
  background-color: var(--color-pink);
  color: #fff;
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 700;
  min-height: 2.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.announcement-bar a {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
}

/* ── Desktop weergave ──────────────────────────────────── */
.announcement-bar__desktop {
  display: none;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0 48px;
  width: 100%;
}

@media (min-width: 750px) {
  .announcement-bar__desktop { display: flex; }
  .announcement-bar__mobile  { display: none; }
}

.announcement-bar__item {
  display: none;
  align-items: center;
  gap: 6px;
  justify-content: center;
}

.announcement-bar__item--active {
  display: flex;
}

.announcement-bar__icon {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.announcement-bar__icon svg {
  width: 14px;
  height: 14px;
}

.announcement-bar__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: transparent;
  border: none;
  color: #fff;
  cursor: pointer;
  padding: 4px;
  display: flex;
  align-items: center;
  opacity: 0.7;
  transition: opacity 150ms ease;
}

.announcement-bar__arrow:hover { opacity: 1; }
.announcement-bar__arrow--prev { left: 12px; }
.announcement-bar__arrow--next { right: 12px; }

/* ── Mobiel: CSS marquee ───────────────────────────────── */
.announcement-bar__mobile {
  display: flex;
  width: 100%;
  overflow: hidden;
}

.announcement-bar__marquee {
  display: flex;
  width: 100%;
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
}

.announcement-bar__marquee-track {
  display: flex;
  align-items: center;
  gap: 0;
  white-space: nowrap;
  animation: announcement-scroll 24s linear infinite;
  will-change: transform;
}

@media (prefers-reduced-motion: reduce) {
  .announcement-bar__marquee-track {
    animation: none;
  }
}

.announcement-bar__marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0 20px;
}

.announcement-bar__separator {
  margin-left: 20px;
  opacity: 0.5;
}

@keyframes announcement-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
{% endstylesheet %}

{% javascript %}
(function () {
  const bar = document.querySelector('[data-announcement-bar]');
  if (!bar) return;

  const items    = bar.querySelectorAll('.announcement-bar__item');
  const interval = parseInt(bar.dataset.interval, 10) || 4000;
  if (items.length <= 1) return;

  let current = 0;
  let timer   = null;

  function show(index) {
    items[current].classList.remove('announcement-bar__item--active');
    current = (index + items.length) % items.length;
    items[current].classList.add('announcement-bar__item--active');
  }

  function start() {
    timer = setInterval(() => show(current + 1), interval);
  }

  function stop() {
    clearInterval(timer);
  }

  const prevBtn = bar.querySelector('.announcement-bar__arrow--prev');
  const nextBtn = bar.querySelector('.announcement-bar__arrow--next');

  if (prevBtn) {
    prevBtn.addEventListener('click', () => { stop(); show(current - 1); start(); });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', () => { stop(); show(current + 1); start(); });
  }

  bar.addEventListener('mouseenter', stop);
  bar.addEventListener('mouseleave', start);

  start();
}());
{% endjavascript %}

{% schema %}
{
  "name": "Aankondigingsbalk",
  "tag": "aside",
  "blocks": [
    {
      "type": "message",
      "name": "Bericht",
      "limit": 5,
      "settings": [
