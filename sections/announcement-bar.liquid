{%- comment -%}sections/announcement-bar.liquid — Kwispelbox KB-v3{%- endcomment -%}

{%- assign msg_blocks = section.blocks | where: 'type', 'message' -%}
{%- if msg_blocks.size > 0 -%}

{%- comment -%}Marquee snelheid als CSS custom property{%- endcomment -%}
{% style %}
  #shopify-section-{{ section.id }} .ann-bar__track {
    animation-duration: {{ section.settings.marquee_speed }}s;
  }
{% endstyle %}

<div class="ann-bar full-width" role="region" aria-label="Aankondigingen"
     data-ann-bar data-interval="{{ section.settings.rotation_interval | times: 1000 }}">

  <div class="ann-bar__inner">

    <div class="ann-bar__desktop" aria-live="polite" aria-atomic="true">
      {%- for block in msg_blocks -%}
        <div class="ann-bar__item{% if forloop.first %} ann-bar__item--active{% endif %}"
             data-ann-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <span class="ann-bar__icon" aria-hidden="true">
              {{- block.settings.icon | inline_asset_content -}}
            </span>
          {%- endif -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="ann-bar__text">{{ block.settings.text }}</a>
          {%- else -%}
            <span class="ann-bar__text">{{ block.settings.text }}</span>
          {%- endif -%}
        </div>
      {%- endfor -%}
      {%- if msg_blocks.size > 1 and section.settings.show_arrows -%}
        <button class="ann-bar__btn ann-bar__btn--prev" aria-label="Vorig bericht">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg>
        </button>
        <button class="ann-bar__btn ann-bar__btn--next" aria-label="Volgend bericht">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      {%- endif -%}
    </div>

    <div class="ann-bar__mobile" aria-hidden="true">
      <div class="ann-bar__marquee">
        <div class="ann-bar__track">
          {%- for i in (1..2) -%}
            {%- for block in msg_blocks -%}
              <span class="ann-bar__marquee-item">
                {%- if block.settings.icon != blank -%}
                  <span class="ann-bar__icon">{{- block.settings.icon | inline_asset_content -}}</span>
                {%- endif -%}
                {{- block.settings.text -}}
                <span aria-hidden="true">&nbsp;·&nbsp;</span>
              </span>
            {%- endfor -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

  </div>
</div>
{%- endif -%}

{% stylesheet %}
.ann-bar {
  background-color: var(--color-pink);
  color: #fff;
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 700;
  min-height: 2.5rem;
  position: relative;
  overflow: hidden;
}

.ann-bar__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 2.5rem;
}

.ann-bar a {
  color: inherit;
  text-decoration: underline;
  text-underline-offset: 2px;
}

/* Desktop: roterende berichten */
.ann-bar__desktop {
  display: none;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 0 48px;
  width: 100%;
}
@media (min-width: 750px) {
  .ann-bar__desktop { display: flex; }
  .ann-bar__mobile  { display: none; }
}

.ann-bar__item { display: none; align-items: center; gap: 6px; }
.ann-bar__item--active { display: flex; }
.ann-bar__icon { display: flex; align-items: center; flex-shrink: 0; }
.ann-bar__icon svg { width: 14px; height: 14px; }

.ann-bar__btn {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: transparent; border: none; color: #fff;
  cursor: pointer; padding: 4px; display: flex;
  align-items: center; opacity: 0.7; transition: opacity 150ms;
}
.ann-bar__btn:hover { opacity: 1; }
.ann-bar__btn--prev { left: 12px; }
.ann-bar__btn--next { right: 12px; }

/* Mobiel: doorlopende marquee */
.ann-bar__mobile {
  display: flex;
  width: 100%;
  overflow: hidden;
}
.ann-bar__marquee {
  display: flex;
  width: 100%;
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
}
.ann-bar__track {
  display: flex;
  align-items: center;
  white-space: nowrap;
  animation: ann-scroll 30s linear infinite;
  will-change: transform;
}
@media (prefers-reduced-motion: reduce) {
  .ann-bar__track { animation: none; }
}
.ann-bar__marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0 20px;
}
@keyframes ann-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
{% endstylesheet %}

{% javascript %}
(function(){
  var bar=document.querySelector('[data-ann-bar]');
  if(!bar)return;
  var items=bar.querySelectorAll('.ann-bar__item');
  var interval=parseInt(bar.dataset.interval,10)||4000;
  if(items.length<=1)return;
  var cur=0,timer=null;
  function show(i){
    items[cur].classList.remove('ann-bar__item--active');
    cur=(i+items.length)%items.length;
    items[cur].classList.add('ann-bar__item--active');
  }
  function start(){timer=setInterval(function(){show(cur+1);},interval);}
  function stop(){clearInterval(timer);}
  var prev=bar.querySelector('.ann-bar__btn--prev');
  var next=bar.querySelector('.ann-bar__btn--next');
  if(prev)prev.addEventListener('click',function(){stop();show(cur-1);start();});
  if(next)next.addEventListener('click',function(){stop();show(cur+1);start();});
  bar.addEventListener('mouseenter',stop);
  bar.addEventListener('mouseleave',start);
  start();
}());
{% endjavascript %}

{% schema %}
{
  "name": "Aankondigingsbalk",
  "tag": "aside",
  "class": "full-width",
  "blocks": [
    {
      "type": "message",
      "name": "Bericht",
      "limit": 5,
      "settings": [
        { "type": "text",   "id": "text", "label": "Berichttekst", "default": "Gratis verzending vanaf 75 euro" },
        { "type": "url",    "id": "link", "label": "Link (optioneel)" },
        { "type": "select", "id": "icon", "label": "Icoon", "default": "icon-truck.svg",
          "options": [
            { "value": "icon-truck.svg",  "label": "Vrachtwagen" },
            { "value": "icon-heart.svg",  "label": "Hart" },
            { "value": "icon-shield.svg", "label": "Schild" },
            { "value": "icon-gift.svg",   "label": "Cadeau" },
            { "value": "icon-star.svg",   "label": "Ster" },
            { "value": "icon-paw.svg",    "label": "Poot" },
            { "value": "",                "label": "Geen icoon" }
          ]
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "range",
      "id": "rotation_interval",
      "label": "Rotatietijd desktop (seconden)",
      "min": 2, "max": 10, "step": 1, "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Pijltjes tonen",
      "default": true
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Scrollsnelheid mobiel (seconden)",
      "info": "Lager = sneller, hoger = langzamer",
      "min": 10, "max": 60, "step": 5, "default": 30
    }
  ],
  "presets": [
    {
      "name": "Aankondigingsbalk",
      "blocks": [
        { "type": "message", "settings": { "text": "Vandaag besteld, morgen in huis", "icon": "icon-truck.svg" } },
        { "type": "message", "settings": { "text": "Gratis verzending vanaf 75 euro",  "icon": "icon-gift.svg" } },
        { "type": "message", "settings": { "text": "100% blije honden garantie",       "icon": "icon-heart.svg" } },
        { "type": "message", "settings": { "text": "Klanten beoordelen ons met 4,9/5","icon": "icon-star.svg" } }
      ]
    }
  ]
}
{% endschema %}
