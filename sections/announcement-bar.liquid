{%- assign msg_blocks = section.blocks | where: 'type', 'message' -%}
{%- if msg_blocks.size > 0 -%}
<div class="ann-bar" role="region" aria-label="Aankondigingen"
     data-ann-bar data-interval="{{ section.settings.rotation_interval | times: 1000 }}">
  <div class="ann-bar__desktop" aria-live="polite">
    {%- for block in msg_blocks -%}
      <div class="ann-bar__item{% if forloop.first %} ann-bar__item--active{% endif %}"
           data-ann-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        {%- if block.settings.icon != blank -%}<span class="ann-bar__icon" aria-hidden="true">{{- block.settings.icon | inline_asset_content -}}</span>{%- endif -%}
        {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" class="ann-bar__text">{{ block.settings.text }}</a>
        {%- else -%}<span class="ann-bar__text">{{ block.settings.text }}</span>{%- endif -%}
      </div>
    {%- endfor -%}
    {%- if msg_blocks.size > 1 and section.settings.show_arrows -%}
      <button class="ann-bar__btn ann-bar__btn--prev" aria-label="Vorig bericht"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5"/><path d="m12 5-7 7 7 7"/></svg></button>
      <button class="ann-bar__btn ann-bar__btn--next" aria-label="Volgend bericht"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></button>
    {%- endif -%}
  </div>
  <div class="ann-bar__mobile" aria-hidden="true">
    <div class="ann-bar__marquee"><div class="ann-bar__track">
      {%- for i in (1..2) -%}{%- for block in msg_blocks -%}
        <span class="ann-bar__marquee-item">
          {%- if block.settings.icon != blank -%}<span class="ann-bar__icon">{{- block.settings.icon | inline_asset_content -}}</span>{%- endif -%}
          {{- block.settings.text -}}<span aria-hidden="true"> · </span>
        </span>
      {%- endfor -%}{%- endfor -%}
    </div></div>
  </div>
</div>
{%- endif -%}

{% stylesheet %}
.ann-bar{background-color:var(--color-pink);color:#fff;font-family:var(--font-body);font-size:.8rem;font-weight:700;min-height:2.5rem;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.ann-bar a{color:inherit;text-decoration:underline;text-underline-offset:2px;}
.ann-bar__desktop{display:none;align-items:center;justify-content:center;gap:8px;padding:0 48px;width:100%;}
@media(min-width:750px){.ann-bar__desktop{display:flex;}.ann-bar__mobile{display:none;}}
.ann-bar__item{display:none;align-items:center;gap:6px;}
.ann-bar__item--active{display:flex;}
.ann-bar__icon{display:flex;align-items:center;flex-shrink:0;}
.ann-bar__icon svg{width:14px;height:14px;}
.ann-bar__btn{position:absolute;top:50%;transform:translateY(-50%);background:transparent;border:none;color:#fff;cursor:pointer;padding:4px;display:flex;align-items:center;opacity:.7;transition:opacity 150ms;}
.ann-bar__btn:hover{opacity:1;}
.ann-bar__btn--prev{left:12px;}
.ann-bar__btn--next{right:12px;}
.ann-bar__mobile{display:flex;width:100%;overflow:hidden;}
.ann-bar__marquee{display:flex;width:100%;overflow:hidden;mask-image:linear-gradient(to right,transparent 0%,black 8%,black 92%,transparent 100%);-webkit-mask-image:linear-gradient(to right,transparent 0%,black 8%,black 92%,transparent 100%);}
.ann-bar__track{display:flex;align-items:center;white-space:nowrap;animation:ann-scroll 24s linear infinite;will-change:transform;}
@media(prefers-reduced-motion:reduce){.ann-bar__track{animation:none;}}
.ann-bar__marquee-item{display:inline-flex;align-items:center;gap:6px;padding:0 20px;}
@keyframes ann-scroll{from{transform:translateX(0);}to{transform:translateX(-50%);}}
{% endstylesheet %}

{% javascript %}
(function(){
  var bar=document.querySelector('[data-ann-bar]');
  if(!bar)return;
  var items=bar.querySelectorAll('.ann-bar__item');
  var interval=parseInt(bar.dataset.interval,10)||4000;
  if(items.length<=1)return;
  var cur=0,timer=null;
  function show(i){items[cur].classList.remove('ann-bar__item--active');cur=(i+items.length)%items.length;items[cur].classList.add('ann-bar__item--active');}
  function start(){timer=setInterval(function(){show(cur+1);},interval);}
  function stop(){clearInterval(timer);}
  var prev=bar.querySelector('.ann-bar__btn--prev');
  var next=bar.querySelector('.ann-bar__btn--next');
  if(prev)prev.addEventListener('click',function(){stop();show(cur-1);start();});
  if(next)next.addEventListener('click',function(){stop();show(cur+1);start();});
  bar.addEventListener('mouseenter',stop);
  bar.addEventListener('mouseleave',start);
  start();
}());
{% endjavascript %}

