{%- comment -%}
  sections/header.liquid — Kwispelbox KB-v3
  5 rijke dropdown layouts per menu-item:
  - standard:    2-koloms links + banner (Special Editions)
  - featured:    featured products + links (Verrassingsboxen)
  - categories:  sub-categorie kolommen met foto (Shop)
  - club:        Kwispelclub layout
  - about:       Over ons brand layout
{%- endcomment -%}

{%- assign trust_blocks    = section.blocks | where: 'type', 'trust_item' -%}
{%- assign dd_blocks       = section.blocks | where: 'type', 'dropdown_config' -%}
{%- assign col_blocks      = section.blocks | where: 'type', 'dropdown_col' -%}
{%- assign prod_blocks     = section.blocks | where: 'type', 'dropdown_product' -%}

<div class="site-header__wrapper">

  <!-- ══ HOOFDBALK ════════════════════════════════════ -->
  <header class="site-header" role="banner">
    <div class="site-header__inner">

      <button class="site-header__burger"
              aria-expanded="false"
              aria-controls="header-drawer"
              aria-label="Menu openen">
        {{- 'icon-menu.svg' | inline_asset_content -}}
      </button>

      <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            srcset="{{ section.settings.logo | image_url: width: 200 }} 200w,
                    {{ section.settings.logo | image_url: width: 400 }} 400w"
            sizes="{{ section.settings.logo_width }}px"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
            loading="eager" fetchpriority="high" class="site-header__logo-img">
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      {%- if section.settings.menu != blank -%}
        <nav class="site-header__nav" aria-label="Hoofdnavigatie">
          <ul class="site-header__chips" role="list">
            {%- for link in section.settings.menu.links -%}
              {%- assign lx = forloop.index -%}
              {%- assign dd = nil -%}
              {%- for b in dd_blocks -%}
                {%- if b.settings.menu_item_index == lx -%}{%- assign dd = b -%}{%- endif -%}
              {%- endfor -%}
              {%- assign has_dd = false -%}
              {%- if dd != nil or link.links.size > 0 -%}{%- assign has_dd = true -%}{%- endif -%}

              <li class="site-header__chip-item{% if has_dd %} site-header__chip-item--has-dd{% endif %}" data-nav-item>

                <a href="{{ link.url }}"
                   class="site-header__chip{% if dd %} site-header__chip--{{ dd.settings.accent_color }}{% endif %}"
                   {% if link.active %}aria-current="page"{% endif %}
                   {% if has_dd %}aria-haspopup="true" aria-expanded="false" data-nav-trigger{% endif %}>
                  {{ link.title }}
                  {%- if has_dd -%}
                    <span class="site-header__chip-chevron" aria-hidden="true">
                      {{- 'icon-chevron-down.svg' | inline_asset_content -}}
                    </span>
                  {%- endif -%}
                </a>

                {%- if has_dd -%}
                  <div class="site-header__dropdown" data-nav-dropdown>
                    <div class="site-header__dropdown-card">
                      {%- assign layout = dd.settings.layout_type | default: 'standard' -%}

                      {%- comment -%} ══ LAYOUT: FEATURED / MEGA (Verrassingsboxen) ══ {%- endcomment -%}
                      {%- if layout == 'featured' -%}
                        <div class="dd-verr">

                          {%- comment -%} Kolom 1: Verrassingsboxen — producten + extra links {%- endcomment -%}
                          <div class="dd-verr__col dd-verr__col--products">
                            <div class="dd-verr__col-head">
                              <span class="dd-verr__col-icon dd-verr__col-icon--{{ dd.settings.accent_color }}" aria-hidden="true">
                                {{- 'icon-gift.svg' | inline_asset_content -}}
                              </span>
                              <div>
                                <a href="{{ link.url }}" class="dd-verr__col-title dd-verr__col-title--{{ dd.settings.accent_color }}">{{ link.title }}</a>
                                {%- if dd.settings.col1_desc != blank -%}
                                  <p class="dd-verr__col-desc">{{ dd.settings.col1_desc }}</p>
                                {%- endif -%}
                              </div>
                            </div>

                            <div class="dd-verr__products">
                              {%- for pb in prod_blocks -%}
                                {%- if pb.settings.menu_item_index == lx -%}
                                  {%- assign p = pb.settings.product -%}
                                  {%- if p != blank -%}
                                    <a href="{{ p.url }}" class="dd-verr__product" {{ pb.shopify_attributes }}>
                                      {%- if p.featured_image -%}
                                        <img src="{{ p.featured_image | image_url: width: 140 }}"
                                             alt="{{ p.featured_image.alt | default: p.title | escape }}"
                                             width="70" height="70" loading="lazy"
                                             class="dd-verr__product-img">
                                      {%- endif -%}
                                      <div class="dd-verr__product-info">
                                        <div class="dd-verr__product-name-row">
                                          <strong>{{ p.title }}</strong>
                                          {%- if pb.settings.badge != blank -%}
                                            <span class="dd-verr__product-badge">{{ pb.settings.badge }}</span>
                                          {%- endif -%}
                                        </div>
                                        {%- if pb.settings.description != blank -%}
                                          <span class="dd-verr__product-desc">{{ pb.settings.description }}</span>
                                        {%- endif -%}
                                      </div>
                                      <svg class="dd-verr__chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                                    </a>
                                  {%- endif -%}
                                {%- endif -%}
                              {%- endfor -%}
                            </div>

                            {%- if dd.settings.link_list != blank -%}
                              <ul class="dd-verr__extra-links" role="list">
                                {%- for child in dd.settings.link_list.links -%}
                                  <li>
                                    <a href="{{ child.url }}" class="dd-verr__extra-link">
                                      <span class="dd-verr__link-icon dd-verr__link-icon--{{ dd.settings.accent_color }}" aria-hidden="true">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 12v10H4V12"/><path d="M2 7h20v5H2z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                                      </span>
                                      <span>{{ child.title }}</span>
                                      <svg class="dd-verr__chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            {%- endif -%}
                          </div>

                          {%- comment -%} Kolommen 2-N via dropdown_col blocks {%- endcomment -%}
                          {%- for cb in col_blocks -%}
                            {%- if cb.settings.menu_item_index == lx -%}
                              <div class="dd-verr__col" {{ cb.shopify_attributes }}>
                                <div class="dd-verr__col-head">
                                  <span class="dd-verr__col-icon dd-verr__col-icon--{{ cb.settings.color }}" aria-hidden="true">
                                    {{- cb.settings.icon | inline_asset_content -}}
                                  </span>
                                  <div>
                                    <a href="{{ cb.settings.cta_url | default: '#' }}" class="dd-verr__col-title dd-verr__col-title--{{ cb.settings.color }}">{{ cb.settings.heading }}</a>
                                    {%- if cb.settings.description != blank -%}
                                      <p class="dd-verr__col-desc">{{ cb.settings.description }}</p>
                                    {%- endif -%}
                                  </div>
                                </div>

                                {%- if cb.settings.link_list != blank -%}
                                  <ul class="dd-verr__col-links" role="list">
                                    {%- for child in cb.settings.link_list.links limit: 8 -%}
                                      <li>
                                        <a href="{{ child.url }}" class="dd-verr__col-link">
                                          {%- if cb.settings.show_link_icons -%}
                                            <span class="dd-verr__link-icon dd-verr__link-icon--{{ cb.settings.color }}" aria-hidden="true">
                                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="4" cy="8" r="2"/><path d="M11 4c-3 4-5 6-5 10a7 7 0 0 0 14 0c0-4-2-6-5-10"/><circle cx="15" cy="14" r="1"/><circle cx="9" cy="14" r="1"/></svg>
                                            </span>
                                          {%- endif -%}
                                          <span>{{ child.title }}</span>
                                          <svg class="dd-verr__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                {%- endif -%}

                                {%- if cb.settings.cta_label != blank -%}
                                  <a href="{{ cb.settings.cta_url | default: '#' }}" class="dd-verr__col-cta dd-verr__col-cta--{{ cb.settings.color }}">
                                    {{ cb.settings.cta_label }}
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endif -%}

                                {%- comment -%} Mini-banner onderaan kolom (bv. "Nieuw binnen!") {%- endcomment -%}
                                {%- if cb.settings.mini_banner_label != blank -%}
                                  <div class="dd-verr__mini-banner">
                                    <div class="dd-verr__mini-banner-text">
                                      <strong>{{ cb.settings.mini_banner_label }}</strong>
                                      {%- if cb.settings.mini_banner_sub != blank -%}
                                        <span>{{ cb.settings.mini_banner_sub }}</span>
                                      {%- endif -%}
                                      {%- if cb.settings.mini_banner_url != blank -%}
                                        <a href="{{ cb.settings.mini_banner_url }}" class="dd-verr__mini-banner-btn" aria-label="{{ cb.settings.mini_banner_label }}">
                                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                        </a>
                                      {%- endif -%}
                                    </div>
                                    {%- if cb.settings.mini_banner_image != blank -%}
                                      <img src="{{ cb.settings.mini_banner_image | image_url: width: 160 }}"
                                           alt="{{ cb.settings.mini_banner_image.alt | escape }}"
                                           width="80" height="80" loading="lazy"
                                           class="dd-verr__mini-banner-img">
                                    {%- endif -%}
                                  </div>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          {%- endfor -%}

                          {%- comment -%} Banner rechts: cream achtergrond, foto, CTA-knop {%- endcomment -%}
                          {%- if dd.settings.banner_title != blank -%}
                            <div class="dd-verr__banner">
                              <div class="dd-verr__banner-body">
                                <strong class="dd-verr__banner-title">{{ dd.settings.banner_title }}</strong>
                                {%- if dd.settings.banner_text != blank -%}
                                  <span class="dd-verr__banner-text">{{ dd.settings.banner_text }}</span>
                                {%- endif -%}
                              </div>
                              {%- if dd.settings.banner_image != blank -%}
                                <div class="dd-verr__banner-img-wrap">
                                  <img src="{{ dd.settings.banner_image | image_url: width: 500 }}"
                                       alt="{{ dd.settings.banner_image.alt | default: dd.settings.banner_title | escape }}"
                                       width="500" height="340" loading="lazy"
                                       class="dd-verr__banner-img">
                                </div>
                              {%- endif -%}
                              {%- if dd.settings.banner_cta_label != blank -%}
                                <div class="dd-verr__banner-cta-wrap">
                                  <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-verr__banner-cta">
                                    {{ dd.settings.banner_cta_label }}
                                    {{- 'icon-paw.svg' | inline_asset_content -}}
                                  </a>
                                </div>
                              {%- endif -%}
                            </div>
                          {%- endif -%}

                        </div>

                      {%- comment -%} ══ LAYOUT: CATEGORIES (Shop) ══ {%- endcomment -%}
                      {%- elsif layout == 'categories' -%}
                        <div class="dd-categories">
                          {%- for cb in col_blocks -%}
                            {%- if cb.settings.menu_item_index == lx -%}
                              <div class="dd-cat-col dd-cat-col--{{ cb.settings.color }}" {{ cb.shopify_attributes }}>
                                <div class="dd-cat-col__head">
                                  {%- if cb.settings.icon != blank -%}
                                    <span class="dd-cat-col__icon" aria-hidden="true">
                                      {{- cb.settings.icon | inline_asset_content -}}
                                    </span>
                                  {%- endif -%}
                                  <div>
                                    <strong class="dd-cat-col__title">{{ cb.settings.heading }}</strong>
                                    {%- if cb.settings.description != blank -%}
                                      <span class="dd-cat-col__desc">{{ cb.settings.description }}</span>
                                    {%- endif -%}
                                  </div>
                                </div>
                                {%- if cb.settings.link_list != blank -%}
                                  <ul class="dd-cat-col__links" role="list">
                                    {%- for child in cb.settings.link_list.links -%}
                                      <li>
                                        <a href="{{ child.url }}" class="dd-cat-col__link">
                                          <span class="dd-cat-col__link-icon" aria-hidden="true">
                                            {{- 'icon-paw.svg' | inline_asset_content -}}
                                          </span>
                                          {{ child.title }}
                                        </a>
                                      </li>
                                    {%- endfor -%}
                                  </ul>
                                {%- endif -%}
                                {%- if cb.settings.cta_label != blank -%}
                                  <a href="{{ cb.settings.cta_url | default: '#' }}" class="dd-cat-col__cta dd-cat-col__cta--{{ cb.settings.color }}">
                                    {{ cb.settings.cta_label }}
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endif -%}
                                {%- if cb.settings.image != blank -%}
                                  <div class="dd-cat-col__img-wrap" aria-hidden="true">
                                    <img src="{{ cb.settings.image | image_url: width: 280 }}"
                                         alt="{{ cb.settings.image.alt | escape }}"
                                         width="280" height="200" loading="lazy"
                                         class="dd-cat-col__img">
                                  </div>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                          {%- if dd.settings.banner_title != blank -%}
                            <div class="dd-cat-banner">
                              <strong class="dd-cat-banner__title">{{ dd.settings.banner_title }}</strong>
                              {%- if dd.settings.banner_text != blank -%}<span class="dd-cat-banner__text">{{ dd.settings.banner_text }}</span>{%- endif -%}
                              {%- if dd.settings.banner_image != blank -%}
                                <img src="{{ dd.settings.banner_image | image_url: width: 320 }}"
                                     alt="{{ dd.settings.banner_image.alt | escape }}"
                                     width="320" height="200" loading="lazy" class="dd-cat-banner__img">
                              {%- endif -%}
                              {%- if dd.settings.banner_cta_label != blank -%}
                                <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-cta-btn dd-cta-btn--{{ dd.settings.accent_color }}">
                                  {{ dd.settings.banner_cta_label }}
                                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                </a>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </div>

                      {%- comment -%} ══ LAYOUT: CLUB (Kwispelclub) ══ {%- endcomment -%}
                      {%- elsif layout == 'club' -%}
                        <div class="dd-club">
                          <div class="dd-club__intro">
                            <strong class="dd-club__intro-title">{{ dd.settings.club_intro_title }}</strong>
                            {%- if dd.settings.club_intro_text != blank -%}
                              <p class="dd-club__intro-body">{{ dd.settings.club_intro_text }}</p>
                            {%- endif -%}
                            <ul class="dd-club__checks" role="list">
                              {%- if dd.settings.club_check_1 != blank -%}<li>{{- 'icon-check-circle.svg' | inline_asset_content -}}{{ dd.settings.club_check_1 }}</li>{%- endif -%}
                              {%- if dd.settings.club_check_2 != blank -%}<li>{{- 'icon-check-circle.svg' | inline_asset_content -}}{{ dd.settings.club_check_2 }}</li>{%- endif -%}
                              {%- if dd.settings.club_check_3 != blank -%}<li>{{- 'icon-check-circle.svg' | inline_asset_content -}}{{ dd.settings.club_check_3 }}</li>{%- endif -%}
                              {%- if dd.settings.club_check_4 != blank -%}<li>{{- 'icon-check-circle.svg' | inline_asset_content -}}{{ dd.settings.club_check_4 }}</li>{%- endif -%}
                              {%- if dd.settings.club_check_5 != blank -%}<li>{{- 'icon-check-circle.svg' | inline_asset_content -}}{{ dd.settings.club_check_5 }}</li>{%- endif -%}
                            </ul>
                            {%- if dd.settings.club_intro_image != blank -%}
                              <img src="{{ dd.settings.club_intro_image | image_url: width: 240 }}"
                                   alt="{{ dd.settings.club_intro_image.alt | escape }}"
                                   width="240" height="180" loading="lazy" class="dd-club__intro-img">
                            {%- endif -%}
                            {%- if dd.settings.banner_cta_label != blank -%}
                              <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-cta-btn dd-cta-btn--{{ dd.settings.accent_color }}">
                                {{ dd.settings.banner_cta_label }}
                                {{- 'icon-paw.svg' | inline_asset_content -}}
                              </a>
                            {%- endif -%}
                          </div>
                          {%- if dd.settings.link_list != blank -%}
                            <div class="dd-club__links">
                              <ul class="dd-club__link-list" role="list">
                                {%- for child in dd.settings.link_list.links -%}
                                  <li>
                                    <a href="{{ child.url }}" class="dd-club__link">
                                      <span class="dd-club__link-icon dd-link-icon--{{ dd.settings.accent_color }}" aria-hidden="true">
                                        {{- 'icon-paw.svg' | inline_asset_content -}}
                                      </span>
                                      <span class="dd-club__link-text">
                                        <strong>{{ child.title }}</strong>
                                      </span>
                                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                            </div>
                          {%- endif -%}
                          <div class="dd-club__right">
                            {%- if dd.settings.club_rewards_image != blank -%}
                              <div class="dd-club__rewards">
                                <strong class="dd-club__rewards-title">{{ dd.settings.club_rewards_title }}</strong>
                                <img src="{{ dd.settings.club_rewards_image | image_url: width: 320 }}"
                                     alt="{{ dd.settings.club_rewards_title | default: 'Kwispels beloningen' | escape }}"
                                     width="320" height="200" loading="lazy" class="dd-club__rewards-img">
                                {%- if dd.settings.view_all_label != blank -%}
                                  <a href="{{ dd.settings.view_all_url | default: link.url }}" class="dd-view-all dd-view-all--{{ dd.settings.accent_color }}">
                                    {{ dd.settings.view_all_label }}
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                            {%- if dd.settings.club_motm_image != blank -%}
                              <div class="dd-club__motm">
                                <strong class="dd-club__motm-title">{{ dd.settings.club_motm_title }}</strong>
                                <div class="dd-polaroid">
                                  <img src="{{ dd.settings.club_motm_image | image_url: width: 240 }}"
                                       alt="{{ dd.settings.club_motm_name | default: 'Hond van de maand' | escape }}"
                                       width="240" height="180" loading="lazy" class="dd-polaroid__img">
                                  {%- if dd.settings.club_motm_name != blank -%}
                                    <span class="dd-polaroid__label">{{ dd.settings.club_motm_name }}</span>
                                  {%- endif -%}
                                </div>
                                {%- if dd.settings.banner_cta_label != blank -%}
                                  <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-cta-btn dd-cta-btn--pink">
                                    {{- 'icon-camera.svg' | inline_asset_content -}}
                                    Deel jouw foto
                                  </a>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          </div>
                        </div>

                      {%- comment -%} ══ LAYOUT: ABOUT (Over ons) ══ {%- endcomment -%}
                      {%- elsif layout == 'about' -%}
                        <div class="dd-about">
                          {%- if dd.settings.link_list != blank -%}
                            <div class="dd-about__links">
                              <ul class="dd-about__link-list" role="list">
                                {%- for child in dd.settings.link_list.links -%}
                                  <li>
                                    <a href="{{ child.url }}" class="dd-about__link">
                                      <span class="dd-about__link-icon dd-link-icon--{{ dd.settings.accent_color }}" aria-hidden="true">
                                        {{- 'icon-heart.svg' | inline_asset_content -}}
                                      </span>
                                      <span class="dd-about__link-text">
                                        <strong>{{ child.title }}</strong>
                                      </span>
                                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                    </a>
                                  </li>
                                {%- endfor -%}
                              </ul>
                              {%- if dd.settings.about_tagline != blank -%}
                                <div class="dd-about__tagline">
                                  <strong>{{ dd.settings.about_tagline }}</strong>
                                  {%- if dd.settings.about_tagline_sub != blank -%}
                                    <span class="dd-about__tagline-sub">{{ dd.settings.about_tagline_sub }}</span>
                                  {%- endif -%}
                                </div>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          <div class="dd-about__content">
                            <strong class="dd-about__content-title">{{ dd.settings.banner_title }}</strong>
                            {%- if dd.settings.banner_text != blank -%}
                              <p class="dd-about__content-body">{{ dd.settings.banner_text }}</p>
                            {%- endif -%}
                            {%- if dd.settings.banner_cta_label != blank -%}
                              <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-cta-btn dd-cta-btn--{{ dd.settings.accent_color }}">
                                {{ dd.settings.banner_cta_label }}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                              </a>
                            {%- endif -%}
                            {%- if dd.settings.banner_image != blank -%}
                              <img src="{{ dd.settings.banner_image | image_url: width: 400 }}"
                                   alt="{{ dd.settings.banner_image.alt | escape }}"
                                   width="400" height="260" loading="lazy" class="dd-about__content-img">
                            {%- endif -%}
                          </div>
                          {%- if dd.settings.about_team_image != blank or dd.settings.about_team_title != blank -%}
                            <div class="dd-about__team">
                              <strong class="dd-about__team-title">{{ dd.settings.about_team_title }}</strong>
                              {%- if dd.settings.about_team_image != blank -%}
                                <div class="dd-polaroid">
                                  <img src="{{ dd.settings.about_team_image | image_url: width: 280 }}"
                                       alt="{{ dd.settings.about_team_title | default: 'Het team' | escape }}"
                                       width="280" height="200" loading="lazy" class="dd-polaroid__img">
                                </div>
                              {%- endif -%}
                              {%- if dd.settings.about_team_tagline != blank -%}
                                <span class="dd-about__team-tagline">{{ dd.settings.about_team_tagline }}</span>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </div>

                      {%- comment -%} ══ LAYOUT: STANDARD (Special Editions, default) ══ {%- endcomment -%}
                      {%- else -%}
                        <div class="dd-standard">
                          <div class="dd-standard__links-wrap">
                            {%- if dd.settings.link_list != blank -%}
                              <div class="dd-standard__grid">
                                {%- for child in dd.settings.link_list.links -%}
                                  <a href="{{ child.url }}" class="dd-standard__item"
                                     {% if child.active %}aria-current="page"{% endif %}>
                                    <span class="dd-standard__item-icon dd-link-icon--{{ dd.settings.accent_color }}" aria-hidden="true">
                                      {{- 'icon-paw.svg' | inline_asset_content -}}
                                    </span>
                                    <span class="dd-standard__item-text">
                                      <strong>{{ child.title }}</strong>
                                    </span>
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endfor -%}
                              </div>
                            {%- endif -%}
                            {%- if dd.settings.view_all_label != blank -%}
                              <a href="{{ dd.settings.view_all_url | default: link.url }}" class="dd-view-all dd-view-all--{{ dd.settings.accent_color }}">
                                {{ dd.settings.view_all_label }}
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                              </a>
                            {%- endif -%}
                          </div>
                          {%- if dd.settings.banner_title != blank -%}
                            <div class="dd-banner">
                              {%- if dd.settings.banner_image != blank -%}
                                <div class="dd-banner__img-wrap">
                                  <img src="{{ dd.settings.banner_image | image_url: width: 600 }}"
                                       alt="{{ dd.settings.banner_image.alt | default: dd.settings.banner_title | escape }}"
                                       width="600" height="400" loading="lazy" class="dd-banner__img">
                                  {%- if dd.settings.banner_badge != blank -%}
                                    <span class="dd-banner__badge dd-banner__badge--{{ dd.settings.accent_color }}">{{ dd.settings.banner_badge }}</span>
                                  {%- endif -%}
                                </div>
                              {%- endif -%}
                              <div class="dd-banner__body">
                                <strong class="dd-banner__title">{{ dd.settings.banner_title }}</strong>
                                {%- if dd.settings.banner_text != blank -%}<span class="dd-banner__text">{{ dd.settings.banner_text }}</span>{%- endif -%}
                                {%- if dd.settings.banner_cta_label != blank -%}
                                  <a href="{{ dd.settings.banner_cta_url | default: link.url }}" class="dd-cta-btn dd-cta-btn--{{ dd.settings.accent_color }}">
                                    {{ dd.settings.banner_cta_label }}
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                                  </a>
                                {%- endif -%}
                              </div>
                            </div>
                          {%- endif -%}
                        </div>
                      {%- endif -%}

                    </div>
                  </div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      <div class="site-header__actions">
        {%- if section.settings.show_search -%}
          <button class="site-header__icon-btn"
                  aria-expanded="false"
                  aria-controls="header-search-panel"
                  aria-label="Zoeken"
                  data-search-toggle>
            {{- 'icon-search.svg' | inline_asset_content -}}
          </button>
        {%- endif -%}
        {%- if shop.customer_accounts_enabled -%}
          <shopify-account menu="{{ section.settings.customer_account_menu }}" class="site-header__account">
            <a href="{{ routes.account_url }}" class="site-header__icon-btn">
              {{- 'icon-account.svg' | inline_asset_content -}}
            </a>
          </shopify-account>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="site-header__icon-btn site-header__cart-btn"
           aria-label="Winkelwagen, {{ cart.item_count }} items">
          {{- 'icon-cart.svg' | inline_asset_content -}}
          {%- if cart.item_count > 0 -%}
            <span class="site-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>
    </div>
  </header>

  <!-- ══ ZOEKPANEEL ═══════════════════════════════════ -->
  {%- if section.settings.show_search -%}
    <div class="site-header__search-panel" id="header-search-panel" aria-hidden="true" data-search-panel>
      <div class="site-header__search-wrap">
        <form action="{{ routes.search_url }}" method="get" role="search" class="site-header__search-form" data-search-form>
          <input type="hidden" name="type" value="product">
          <label for="header-search-input" class="site-header__sr-only">Zoeken</label>
          <div class="site-header__search-field">
            <span class="site-header__search-icon" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
            <input type="search" id="header-search-input" name="q"
              class="site-header__search-input"
              placeholder="{{ section.settings.search_placeholder }}"
              autocomplete="off" autocorrect="off" spellcheck="false"
              data-search-input aria-autocomplete="list" aria-controls="search-results">
            <button type="button" class="site-header__search-clear" aria-label="Wissen" hidden data-search-clear>
              {{- 'icon-close.svg' | inline_asset_content -}}
            </button>
          </div>
          <button type="submit" class="site-header__search-btn">{{ section.settings.search_button_label }}</button>
          <div class="site-header__search-results" id="search-results" role="listbox" hidden data-search-results></div>
        </form>
      </div>
    </div>
  {%- endif -%}

  <!-- ══ TRUST BAR ════════════════════════════════════ -->
  {%- if trust_blocks.size > 0 -%}
    <div class="site-header__trust-bar">
      <div class="site-header__trust-inner">
        {%- for block in trust_blocks -%}
          <div class="site-header__trust-item" {{ block.shopify_attributes }}>
            {%- if block.settings.url != blank -%}<a href="{{ block.settings.url }}" class="site-header__trust-link">{%- else -%}<span class="site-header__trust-link">{%- endif -%}
              <span class="site-header__trust-icon" aria-hidden="true">{{- block.settings.icon | inline_asset_content -}}</span>
              <span class="site-header__trust-text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}<span>{{ block.settings.subtitle }}</span>{%- endif -%}
              </span>
            {%- if block.settings.url != blank -%}</a>{%- else -%}</span>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>

<!-- ══ OVERLAY ══════════════════════════════════════════ -->
<div class="site-header__overlay" id="nav-overlay" aria-hidden="true" data-nav-overlay></div>

<!-- ══ MOBIEL DRAWER ════════════════════════════════════ -->
<div class="header-drawer" id="header-drawer" role="dialog" aria-modal="true" aria-label="Navigatiemenu" aria-hidden="true">
  <div class="header-drawer__header">
    <span class="header-drawer__title">Menu</span>
    <button class="header-drawer__close" aria-label="Sluiten" data-drawer-close>{{- 'icon-close.svg' | inline_asset_content -}}</button>
  </div>
  <form action="{{ routes.search_url }}" method="get" role="search" class="header-drawer__search">
    <input type="hidden" name="type" value="product">
    <label for="drawer-search" class="site-header__sr-only">Zoeken</label>
    <div class="header-drawer__search-field">
      <span aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
      <input type="search" id="drawer-search" name="q" class="header-drawer__search-input" placeholder="{{ section.settings.search_placeholder }}" autocomplete="off">
    </div>
    <button type="submit" class="header-drawer__search-btn">{{ section.settings.search_button_label }}</button>
  </form>
  <nav aria-label="Mobiel menu">
    <ul class="header-drawer__nav" role="list">
      {%- for link in section.settings.menu.links -%}
        <li class="header-drawer__nav-item{% if link.links.size > 0 %} header-drawer__nav-item--has-sub{% endif %}">
          <div class="header-drawer__nav-row">
            <a href="{{ link.url }}" class="header-drawer__nav-link" {% if link.active %}aria-current="page"{% endif %}>{{ link.title }}</a>
            {%- if link.links.size > 0 -%}
              <button class="header-drawer__sub-toggle" aria-expanded="false" aria-label="{{ link.title }} submenu">{{- 'icon-chevron-down.svg' | inline_asset_content -}}</button>
            {%- endif -%}
          </div>
          {%- if link.links.size > 0 -%}
            <ul class="header-drawer__sub-nav" role="list" hidden>
              {%- for child in link.links -%}
                <li><a href="{{ child.url }}" class="header-drawer__sub-link" {% if child.active %}aria-current="page"{% endif %}>{{ child.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>
  {%- if shop.customer_accounts_enabled -%}
    <div class="header-drawer__footer">
      <a href="{{ routes.account_url }}" class="header-drawer__account-link">
        {{- 'icon-account.svg' | inline_asset_content -}}
        {%- if customer -%}Mijn account{%- else -%}{{ section.settings.account_label }}{%- endif -%}
      </a>
    </div>
  {%- endif -%}
</div>
<div class="header-drawer__overlay" id="header-overlay" aria-hidden="true" data-drawer-overlay></div>

{% stylesheet %}
/* ── Helpers ──────────────────────────────────────────── */
.site-header__sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;}

/* ── Wrapper ──────────────────────────────────────────── */
.site-header__wrapper{position:sticky;top:0;z-index:100;background:#fff;}

/* ── Hoofdbalk ────────────────────────────────────────── */
.site-header{background:#fff;border-bottom:1.5px solid var(--color-line);}
.site-header__inner{max-width:var(--page-width);margin:0 auto;padding:0 var(--page-margin);height:72px;display:flex;align-items:center;gap:20px;}

/* ── Hamburger ────────────────────────────────────────── */
.site-header__burger{display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;padding:6px;color:var(--color-ink);flex-shrink:0;}
.site-header__burger svg{width:24px;height:24px;}
@media(min-width:990px){.site-header__burger{display:none;}}

/* ── Logo ─────────────────────────────────────────────── */
.site-header__logo{display:flex;align-items:center;text-decoration:none;flex-shrink:0;}
.site-header__logo-img{height:auto;max-height:52px;width:auto;display:block;}
.site-header__logo-text{font-family:var(--font-heading);font-size:1.6rem;color:var(--color-ink);white-space:nowrap;}

/* ── Navigatie ────────────────────────────────────────── */
.site-header__nav{flex:1;display:flex;justify-content:center;}
@media(max-width:989px){.site-header__nav{display:none;}}
.site-header__chips{display:flex;align-items:center;gap:2px;list-style:none;margin:0;padding:0;}
.site-header__chip-item{position:static;}
.site-header__chip{display:inline-flex;align-items:center;gap:5px;padding:8px 14px;border-radius:var(--radius-pill);font-family:var(--font-body);font-size:.88rem;font-weight:700;text-decoration:none;white-space:nowrap;color:var(--color-ink);background:none;border:none;cursor:pointer;transition:background 160ms,color 160ms;}
.site-header__chip:hover,.site-header__chip[aria-current="page"]{background:var(--color-cream);}
.site-header__chip[aria-expanded="true"]{background:var(--color-cream);}
.site-header__chip--green{color:var(--color-green);}.site-header__chip--green:hover,.site-header__chip--green[aria-expanded="true"]{background:#e8f5e2;}
.site-header__chip--pink{color:var(--color-pink);}.site-header__chip--pink:hover,.site-header__chip--pink[aria-expanded="true"]{background:#ffe0ee;}
.site-header__chip--orange{color:var(--color-orange);}.site-header__chip--orange:hover,.site-header__chip--orange[aria-expanded="true"]{background:#fff0e4;}
.site-header__chip--yellow{color:var(--color-yellow);}.site-header__chip--yellow:hover,.site-header__chip--yellow[aria-expanded="true"]{background:#fffae0;}
.site-header__chip-chevron{display:inline-flex;align-items:center;margin-left:2px;transition:transform 200ms ease;}
.site-header__chip-chevron svg{width:13px;height:13px;}
.site-header__chip[aria-expanded="true"] .site-header__chip-chevron{transform:rotate(180deg);}

/* ── Iconen ───────────────────────────────────────────── */
.site-header__actions{display:flex;align-items:center;gap:4px;flex-shrink:0;}
.site-header__account{display:flex;}
.site-header__icon-btn{display:flex;align-items:center;justify-content:center;position:relative;background:none;border:none;cursor:pointer;color:var(--color-ink);padding:8px;border-radius:var(--radius-sm);transition:background 160ms;text-decoration:none;}
.site-header__icon-btn:hover{background:var(--color-cream);}
.site-header__icon-btn svg{width:22px;height:22px;}
.site-header__cart-count{position:absolute;top:-4px;right:-4px;background:var(--color-pink);color:#fff;font-family:var(--font-body);font-size:.6rem;font-weight:800;min-width:18px;height:18px;padding:0 4px;border-radius:999px;display:flex;align-items:center;justify-content:center;border:2px solid #fff;}

/* ══ DROPDOWN PANEEL ════════════════════════════════════ */
.site-header__dropdown{
  position:fixed;
  left:0;right:0;
  top:var(--header-bottom, 72px);
  background:transparent;
  z-index:99;
  opacity:0;visibility:hidden;
  transform:translateY(-6px);
  transition:opacity 200ms ease,visibility 200ms ease,transform 200ms ease;
  pointer-events:none;
  padding:8px var(--page-margin) 0;
}
.site-header__dropdown[data-open]{opacity:1;visibility:visible;transform:translateY(0);pointer-events:auto;}

.site-header__dropdown-card{
  background:#fff;
  border-radius:20px;
  box-shadow:0 20px 60px rgba(61,34,9,.12);
  border:1.5px solid var(--color-line);
  overflow:hidden;
  max-width:var(--page-width);
  margin:0 auto;
}

/* ── Gedeelde dropdown stijlen ────────────────────────── */
.dd-view-all{display:inline-flex;align-items:center;gap:5px;margin-top:16px;padding-top:12px;border-top:1px solid var(--color-line);font-family:var(--font-body);font-size:.85rem;font-weight:800;text-decoration:none;transition:gap 160ms;}
.dd-view-all:hover{gap:8px;}
.dd-view-all svg{width:14px;height:14px;}
.dd-view-all--green{color:var(--color-green);}
.dd-view-all--pink{color:var(--color-pink);}
.dd-view-all--orange{color:var(--color-orange);}
.dd-view-all--yellow{color:var(--color-yellow);}
.dd-view-all--ink{color:var(--color-ink);}

.dd-cta-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:11px 20px;font-family:var(--font-heading);font-size:.88rem;text-decoration:none;border-radius:var(--radius-pill);transition:background 160ms,transform 160ms;border:none;cursor:pointer;}
.dd-cta-btn:hover{transform:translateY(-1px);}
.dd-cta-btn svg{width:15px;height:15px;}
.dd-cta-btn--green{background:var(--color-green);color:#fff;}
.dd-cta-btn--green:hover{background:#4d8833;}
.dd-cta-btn--pink{background:var(--color-pink);color:#fff;}
.dd-cta-btn--pink:hover{background:#c4396a;}
.dd-cta-btn--orange{background:var(--color-orange);color:#fff;}
.dd-cta-btn--orange:hover{background:#d9823a;}
.dd-cta-btn--yellow{background:var(--color-yellow);color:var(--color-ink);}
.dd-cta-btn--ink{background:var(--color-ink);color:#fff;}
.dd-cta-btn--ink:hover{background:#5a3210;}

.dd-link-icon{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.dd-link-icon svg{width:16px;height:16px;}
.dd-link-icon--green{background:#e8f5e2;color:var(--color-green);}
.dd-link-icon--pink{background:#ffe0ee;color:var(--color-pink);}
.dd-link-icon--orange{background:#fff0e4;color:var(--color-orange);}
.dd-link-icon--yellow{background:#fffae0;color:var(--color-yellow);}
.dd-link-icon--ink{background:var(--color-cream);color:var(--color-ink);}

.dd-banner{width:280px;flex-shrink:0;border-left:1.5px solid var(--color-line);display:flex;flex-direction:column;}
.dd-banner--featured{border-left:none;border-top:1.5px solid var(--color-line);width:100%;flex-direction:row;gap:20px;}
.dd-banner__img-wrap{position:relative;overflow:hidden;}
.dd-banner__img{width:100%;height:220px;object-fit:cover;display:block;}
.dd-banner--featured .dd-banner__img{width:200px;height:160px;border-radius:var(--radius-md);}
.dd-banner__badge{position:absolute;top:12px;left:12px;background:var(--color-green);color:#fff;font-family:var(--font-heading);font-size:.72rem;padding:4px 12px;border-radius:var(--radius-pill);}
.dd-banner__badge--pink{background:var(--color-pink);}
.dd-banner__badge--orange{background:var(--color-orange);}
.dd-banner__badge--yellow{background:var(--color-yellow);color:var(--color-ink);}
.dd-banner__body{padding:16px;display:flex;flex-direction:column;gap:8px;flex:1;}
.dd-banner__title{font-family:var(--font-heading);font-size:1.1rem;color:var(--color-ink);line-height:1.2;}
.dd-banner__text{font-family:var(--font-body);font-size:.82rem;color:var(--color-muted);line-height:1.5;}

/* Polaroid component */
.dd-polaroid{background:#fff;padding:8px 8px 36px;border-radius:3px;box-shadow:0 4px 16px rgba(61,34,9,.12);transform:rotate(-2deg);position:relative;display:inline-block;}
.dd-polaroid__img{width:100%;border-radius:2px;display:block;height:160px;object-fit:cover;}
.dd-polaroid__label{position:absolute;bottom:8px;left:0;right:0;text-align:center;font-family:var(--font-heading);font-size:.85rem;color:var(--color-ink);}

/* ── STANDARD layout ──────────────────────────────────── */
.dd-standard{display:flex;gap:0;}
.dd-standard__links-wrap{flex:1;padding:24px 28px;display:flex;flex-direction:column;}
.dd-standard__grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;flex:1;}
.dd-standard__item{display:flex;align-items:center;gap:12px;padding:10px 10px;border-radius:var(--radius-sm);text-decoration:none;color:var(--color-ink);transition:background 120ms;}
.dd-standard__item:hover{background:var(--color-cream);}
.dd-standard__item:hover svg{opacity:1;transform:translateX(2px);}
.dd-standard__item-text strong{font-family:var(--font-body);font-size:.9rem;font-weight:700;}
.dd-standard__item svg{width:13px;height:13px;color:var(--color-muted);opacity:.4;transition:opacity 120ms,transform 120ms;margin-left:auto;}

/* ── FEATURED layout (Verrassingsboxen) ───────────────── */
.dd-featured{display:flex;gap:0;flex-wrap:wrap;}
.dd-featured__products{display:flex;gap:1px;flex:1;min-width:0;}
.dd-featured__product{display:flex;flex-direction:column;flex:1;text-decoration:none;color:var(--color-ink);transition:background 120ms;position:relative;padding:24px 20px 20px;}
.dd-featured__product:hover{background:var(--color-cream);}
.dd-featured__product-badge{position:absolute;top:16px;left:16px;background:var(--color-pink);color:#fff;font-family:var(--font-body);font-size:.68rem;font-weight:800;padding:3px 10px;border-radius:999px;}
.dd-featured__product-img{width:100%;height:160px;object-fit:cover;border-radius:var(--radius-md);margin-bottom:12px;}
.dd-featured__product-info{display:flex;flex-direction:column;gap:3px;}
.dd-featured__product-info strong{font-family:var(--font-heading);font-size:.95rem;color:var(--color-ink);}
.dd-featured__product-info span{font-family:var(--font-body);font-size:.78rem;color:var(--color-muted);}
.dd-featured__product-price{font-family:var(--font-heading);font-size:.9rem;color:var(--color-green);margin-top:4px;}
.dd-featured__extra{width:200px;flex-shrink:0;border-left:1.5px solid var(--color-line);padding:24px 20px;display:flex;flex-direction:column;}
.dd-featured__links{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:2px;flex:1;}
.dd-featured__link{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:var(--radius-sm);text-decoration:none;color:var(--color-ink);font-family:var(--font-body);font-size:.88rem;font-weight:600;transition:background 120ms;}
.dd-featured__link:hover{background:var(--color-cream);}
.dd-featured__link svg{margin-left:auto;width:13px;height:13px;color:var(--color-muted);opacity:.4;}
.dd-featured__link:hover svg{opacity:1;}
.dd-featured__link-icon.dd-link-icon--green{background:#e8f5e2;color:var(--color-green);}

/* ── CATEGORIES layout (Shop) ─────────────────────────── */
.dd-categories{display:flex;gap:0;align-items:stretch;}
.dd-cat-col{flex:1;min-width:0;padding:24px 20px;border-right:1.5px solid var(--color-line);display:flex;flex-direction:column;gap:12px;}
.dd-cat-col:last-of-type{border-right:none;}
.dd-cat-col__head{display:flex;align-items:flex-start;gap:10px;}
.dd-cat-col__icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.dd-cat-col__icon svg{width:22px;height:22px;}
.dd-cat-col--green .dd-cat-col__icon{background:#e8f5e2;color:var(--color-green);}
.dd-cat-col--pink   .dd-cat-col__icon{background:#ffe0ee;color:var(--color-pink);}
.dd-cat-col--orange .dd-cat-col__icon{background:#fff0e4;color:var(--color-orange);}
.dd-cat-col--purple .dd-cat-col__icon{background:#f0ecff;color:#7c3aed;}
.dd-cat-col__title{font-family:var(--font-heading);font-size:1.05rem;display:block;}
.dd-cat-col--green  .dd-cat-col__title{color:var(--color-green);}
.dd-cat-col--pink   .dd-cat-col__title{color:var(--color-pink);}
.dd-cat-col--orange .dd-cat-col__title{color:var(--color-orange);}
.dd-cat-col--purple .dd-cat-col__title{color:#7c3aed;}
.dd-cat-col__desc{font-family:var(--font-body);font-size:.75rem;color:var(--color-muted);line-height:1.4;margin-top:2px;}
.dd-cat-col__links{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:1px;flex:1;}
.dd-cat-col__link{display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:var(--radius-sm);text-decoration:none;font-family:var(--font-body);font-size:.82rem;font-weight:600;color:var(--color-ink);transition:background 120ms;}
.dd-cat-col__link:hover{background:var(--color-cream);}
.dd-cat-col__link-icon{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.dd-cat-col__link-icon svg{width:14px;height:14px;}
.dd-cat-col--green  .dd-cat-col__link-icon{background:#e8f5e2;color:var(--color-green);}
.dd-cat-col--pink   .dd-cat-col__link-icon{background:#ffe0ee;color:var(--color-pink);}
.dd-cat-col--orange .dd-cat-col__link-icon{background:#fff0e4;color:var(--color-orange);}
.dd-cat-col--purple .dd-cat-col__link-icon{background:#f0ecff;color:#7c3aed;}
.dd-cat-col__cta{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;font-family:var(--font-heading);font-size:.8rem;text-decoration:none;border-radius:var(--radius-pill);transition:background 160ms;}
.dd-cat-col__cta svg{width:13px;height:13px;}
.dd-cat-col__cta--green{background:var(--color-green);color:#fff;}.dd-cat-col__cta--green:hover{background:#4d8833;}
.dd-cat-col__cta--pink{background:var(--color-pink);color:#fff;}.dd-cat-col__cta--pink:hover{background:#c4396a;}
.dd-cat-col__cta--orange{background:var(--color-orange);color:#fff;}.dd-cat-col__cta--orange:hover{background:#d9823a;}
.dd-cat-col__cta--purple{background:#7c3aed;color:#fff;}.dd-cat-col__cta--purple:hover{background:#6d28d9;}
.dd-cat-col__img-wrap{margin-top:auto;border-radius:var(--radius-md);overflow:hidden;max-height:140px;}
.dd-cat-col__img{width:100%;height:140px;object-fit:cover;display:block;transition:transform 300ms;}
.dd-cat-col:hover .dd-cat-col__img{transform:scale(1.03);}
.dd-cat-banner{width:180px;flex-shrink:0;padding:24px 20px;display:flex;flex-direction:column;gap:10px;background:var(--color-cream);}
.dd-cat-banner__title{font-family:var(--font-heading);font-size:1rem;color:var(--color-ink);line-height:1.2;}
.dd-cat-banner__text{font-family:var(--font-body);font-size:.78rem;color:var(--color-muted);line-height:1.5;}
.dd-cat-banner__img{width:100%;border-radius:var(--radius-md);object-fit:cover;height:120px;margin:4px 0;}

/* ── CLUB layout ──────────────────────────────────────── */
.dd-club{display:flex;gap:0;}
.dd-club__intro{width:220px;flex-shrink:0;padding:24px 20px;border-right:1.5px solid var(--color-line);display:flex;flex-direction:column;gap:10px;background:var(--color-cream);}
.dd-club__intro-title{font-family:var(--font-heading);font-size:1.1rem;color:var(--color-ink);}
.dd-club__intro-body{font-family:var(--font-body);font-size:.8rem;color:var(--color-muted);line-height:1.5;margin:0;}
.dd-club__checks{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:5px;}
.dd-club__checks li{display:flex;align-items:center;gap:7px;font-family:var(--font-body);font-size:.8rem;font-weight:700;color:var(--color-ink);}
.dd-club__checks svg{width:14px;height:14px;color:var(--color-green);flex-shrink:0;}
.dd-club__intro-img{width:100%;border-radius:var(--radius-md);object-fit:cover;height:120px;margin-top:auto;}
.dd-club__links{flex:1;padding:24px 20px;border-right:1.5px solid var(--color-line);}
.dd-club__link-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:2px;}
.dd-club__link{display:flex;align-items:center;gap:12px;padding:10px 10px;border-radius:var(--radius-md);text-decoration:none;color:var(--color-ink);transition:background 120ms;}
.dd-club__link:hover{background:var(--color-cream);}
.dd-club__link-text strong{display:block;font-family:var(--font-body);font-size:.88rem;font-weight:700;}
.dd-club__link svg{margin-left:auto;width:13px;height:13px;color:var(--color-muted);opacity:.4;transition:opacity 120ms;}
.dd-club__link:hover svg{opacity:1;}
.dd-club__right{width:260px;flex-shrink:0;padding:24px 20px;display:flex;flex-direction:column;gap:20px;}
.dd-club__rewards{display:flex;flex-direction:column;gap:8px;}
.dd-club__rewards-title{font-family:var(--font-heading);font-size:.95rem;color:var(--color-ink);}
.dd-club__rewards-img{width:100%;border-radius:var(--radius-md);object-fit:cover;}
.dd-club__motm{display:flex;flex-direction:column;gap:8px;padding-top:16px;border-top:1.5px solid var(--color-line);}
.dd-club__motm-title{font-family:var(--font-heading);font-size:.95rem;color:var(--color-ink);}

/* ── ABOUT layout ─────────────────────────────────────── */
.dd-about{display:flex;gap:0;}
.dd-about__links{width:220px;flex-shrink:0;padding:24px 20px;border-right:1.5px solid var(--color-line);display:flex;flex-direction:column;}
.dd-about__link-list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:2px;flex:1;}
.dd-about__link{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:var(--radius-sm);text-decoration:none;color:var(--color-ink);transition:background 120ms;}
.dd-about__link:hover{background:var(--color-cream);}
.dd-about__link-text strong{font-family:var(--font-body);font-size:.88rem;font-weight:700;}
.dd-about__link svg{margin-left:auto;width:13px;height:13px;color:var(--color-muted);opacity:.4;transition:opacity 120ms;}
.dd-about__link:hover svg{opacity:1;}
.dd-about__tagline{margin-top:auto;padding-top:16px;border-top:1.5px solid var(--color-line);}
.dd-about__tagline strong{display:block;font-family:var(--font-heading);font-size:.95rem;color:var(--color-ink);}
.dd-about__tagline-sub{font-family:var(--font-body);font-size:.75rem;color:var(--color-muted);}
.dd-about__content{flex:1;padding:24px 24px;border-right:1.5px solid var(--color-line);display:flex;flex-direction:column;gap:10px;}
.dd-about__content-title{font-family:var(--font-heading);font-size:1.2rem;color:var(--color-ink);}
.dd-about__content-body{font-family:var(--font-body);font-size:.88rem;color:var(--color-muted);line-height:1.6;margin:0;}
.dd-about__content-img{width:100%;border-radius:var(--radius-md);object-fit:cover;height:160px;margin-top:auto;}
.dd-about__team{width:220px;flex-shrink:0;padding:24px 20px;display:flex;flex-direction:column;gap:12px;}
.dd-about__team-title{font-family:var(--font-heading);font-size:.95rem;color:var(--color-ink);}
.dd-about__team-tagline{font-family:var(--font-heading);font-size:.85rem;color:var(--color-muted);margin-top:auto;}

/* ── Zoekpaneel ───────────────────────────────────────── */
.site-header__search-panel{background:#fff;border-bottom:1.5px solid var(--color-line);max-height:0;overflow:hidden;transition:max-height 280ms cubic-bezier(.4,0,.2,1);}
.site-header__search-panel[aria-hidden="false"]{max-height:100px;}
@media(max-width:989px){.site-header__search-panel{display:none;}}
.site-header__search-wrap{max-width:var(--page-width);margin:0 auto;padding:12px var(--page-margin);display:flex;justify-content:center;position:relative;}
.site-header__search-form{display:flex;align-items:center;gap:8px;width:100%;max-width:600px;position:relative;}
.site-header__search-field{flex:1;display:flex;align-items:center;background:var(--color-cream);border-radius:var(--radius-pill);border:1.5px solid var(--color-line);padding:0 14px;gap:8px;transition:border-color 160ms;}
.site-header__search-field:focus-within{border-color:var(--color-ink);background:#fff;}
.site-header__search-icon{display:flex;align-items:center;flex-shrink:0;color:var(--color-muted);}
.site-header__search-icon svg{width:16px;height:16px;}
.site-header__search-input{flex:1;height:44px;background:none;border:none;outline:none;font-family:var(--font-body);font-size:.9rem;color:var(--color-ink);min-width:0;}
.site-header__search-input::placeholder{color:var(--color-muted);}
.site-header__search-clear{display:flex;align-items:center;background:none;border:none;cursor:pointer;padding:2px;color:var(--color-muted);}
.site-header__search-clear svg{width:14px;height:14px;}
.site-header__search-btn{height:44px;padding:0 22px;background:var(--color-ink);color:#fff;border:none;border-radius:var(--radius-pill);font-family:var(--font-heading);font-size:.9rem;cursor:pointer;flex-shrink:0;transition:background 160ms;}
.site-header__search-btn:hover{background:#5a3210;}
.site-header__search-results{position:absolute;top:calc(100% + 8px);left:0;right:0;background:#fff;border:1.5px solid var(--color-line);border-radius:var(--radius-md);box-shadow:0 8px 24px rgba(0,0,0,.08);overflow:hidden;z-index:200;}
.search-result-item{display:flex;align-items:center;gap:12px;padding:10px 16px;text-decoration:none;color:var(--color-ink);border-bottom:1px solid var(--color-line);transition:background 120ms;}
.search-result-item:last-child{border-bottom:none;}
.search-result-item:hover,.search-result-item[aria-selected="true"]{background:var(--color-cream);}
.search-result-item__img{width:44px;height:44px;object-fit:cover;border-radius:var(--radius-sm);flex-shrink:0;background:var(--color-cream);}
.search-result-item__title{font-family:var(--font-body);font-size:.88rem;font-weight:700;color:var(--color-ink);}
.search-result-item__price{font-family:var(--font-body);font-size:.82rem;color:var(--color-muted);margin-top:2px;}
.search-result-item__all{display:block;padding:10px 16px;font-family:var(--font-body);font-size:.85rem;font-weight:700;color:var(--color-ink);text-decoration:none;text-align:center;border-top:1px solid var(--color-line);}
.search-result-item__all:hover{background:var(--color-cream);}

/* ── Trust bar ────────────────────────────────────────── */
.site-header__trust-bar{background:#fff;border-top:1.5px solid var(--color-line);}
@media(max-width:989px){.site-header__trust-bar{display:none;}}
.site-header__trust-inner{max-width:var(--page-width);margin:0 auto;padding:0 var(--page-margin);height:44px;display:flex;align-items:center;justify-content:center;}
.site-header__trust-item{display:flex;}
.site-header__trust-link{display:inline-flex;align-items:center;gap:6px;padding:5px 16px;font-family:var(--font-body);font-size:.78rem;font-weight:700;color:var(--color-body);text-decoration:none;border-right:1px solid var(--color-line);transition:color 160ms;white-space:nowrap;}
.site-header__trust-item:last-child .site-header__trust-link{border-right:none;}
.site-header__trust-link:hover{color:var(--color-ink);}
.site-header__trust-icon{display:flex;align-items:center;flex-shrink:0;color:var(--color-muted);}
.site-header__trust-icon svg{width:14px;height:14px;}
.site-header__trust-text strong{font-family:var(--font-body);font-size:.78rem;font-weight:800;color:var(--color-ink);}
.site-header__trust-text span{font-family:var(--font-body);font-size:.7rem;color:var(--color-muted);}

/* ── Overlay ──────────────────────────────────────────── */
.site-header__overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:98;opacity:0;visibility:hidden;transition:opacity 200ms,visibility 200ms;}
.site-header__overlay[aria-hidden="false"]{opacity:1;visibility:visible;}

/* ══ MOBIEL DRAWER ══════════════════════════════════════ */
.header-drawer{position:fixed;top:0;left:0;bottom:0;width:min(320px,85vw);background:#fff;z-index:300;overflow-y:auto;overscroll-behavior:contain;transform:translateX(-100%);transition:transform 280ms cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;}
.header-drawer[aria-hidden="false"]{transform:translateX(0);}
.header-drawer__header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--color-line);flex-shrink:0;}
.header-drawer__title{font-family:var(--font-heading);font-size:1.1rem;color:var(--color-ink);}
.header-drawer__close{display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;padding:4px;color:var(--color-ink);}
.header-drawer__close svg{width:22px;height:22px;}
.header-drawer__search{padding:16px 20px;border-bottom:1px solid var(--color-line);display:flex;gap:8px;flex-shrink:0;}
.header-drawer__search-field{flex:1;display:flex;align-items:center;gap:8px;background:var(--color-cream);border-radius:var(--radius-pill);border:1.5px solid var(--color-line);padding:0 12px;}
.header-drawer__search-field svg{width:16px;height:16px;color:var(--color-muted);flex-shrink:0;}
.header-drawer__search-input{flex:1;height:40px;background:none;border:none;outline:none;font-family:var(--font-body);font-size:.9rem;color:var(--color-ink);min-width:0;}
.header-drawer__search-btn{height:40px;padding:0 16px;background:var(--color-ink);color:#fff;border:none;border-radius:var(--radius-pill);font-family:var(--font-heading);font-size:.85rem;cursor:pointer;flex-shrink:0;}
.header-drawer__nav{list-style:none;margin:0;padding:8px 0;flex:1;}
.header-drawer__nav-item{border-bottom:1px solid var(--color-line);}
.header-drawer__nav-row{display:flex;align-items:center;}
.header-drawer__nav-link{flex:1;padding:14px 20px;text-decoration:none;font-family:var(--font-body);font-size:1rem;font-weight:700;color:var(--color-ink);transition:color 120ms;}
.header-drawer__nav-link:hover,.header-drawer__nav-link[aria-current="page"]{color:var(--color-pink);}
.header-drawer__sub-toggle{background:none;border:none;cursor:pointer;padding:14px 16px;color:var(--color-muted);display:flex;align-items:center;transition:transform 200ms;}
.header-drawer__sub-toggle svg{width:18px;height:18px;}
.header-drawer__sub-toggle[aria-expanded="true"]{transform:rotate(180deg);}
.header-drawer__sub-nav{list-style:none;margin:0;padding:0;background:var(--color-cream);}
.header-drawer__sub-link{display:block;padding:10px 20px 10px 32px;text-decoration:none;font-family:var(--font-body);font-size:.88rem;color:var(--color-body);border-top:1px solid var(--color-line);transition:color 120ms;}
.header-drawer__sub-link:hover{color:var(--color-pink);}
.header-drawer__footer{padding:16px 20px;border-top:1px solid var(--color-line);flex-shrink:0;}
.header-drawer__account-link{display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-family:var(--font-body);font-size:.9rem;font-weight:700;color:var(--color-ink);}
.header-drawer__account-link svg{width:18px;height:18px;}
.header-drawer__overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:299;opacity:0;visibility:hidden;transition:opacity 280ms,visibility 280ms;}
.header-drawer__overlay[aria-hidden="false"]{opacity:1;visibility:visible;}

/* ══ FEATURED layout (Verrassingsboxen) ════════════════ */
.dd-verr{display:flex;gap:0;align-items:stretch;min-height:360px;}
.dd-verr__col{flex:1;min-width:0;padding:20px 18px;border-right:1.5px solid var(--color-line);display:flex;flex-direction:column;gap:10px;}
.dd-verr__col:last-of-type{border-right:none;}
.dd-verr__col--products{flex:1.4;}
.dd-verr__col-head{display:flex;align-items:flex-start;gap:10px;margin-bottom:2px;}
.dd-verr__col-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.dd-verr__col-icon svg{width:18px;height:18px;}
.dd-verr__col-icon--green{background:#e8f5e2;color:var(--color-green);}
.dd-verr__col-icon--pink{background:#ffe0ee;color:var(--color-pink);}
.dd-verr__col-icon--orange{background:#fff0e4;color:var(--color-orange);}
.dd-verr__col-icon--yellow{background:#fffae0;color:var(--color-yellow);}
.dd-verr__col-icon--ink{background:var(--color-cream);color:var(--color-ink);}
.dd-verr__col-title{font-family:var(--font-heading);font-size:1.05rem;text-decoration:none;display:block;line-height:1.2;}
.dd-verr__col-title--green{color:var(--color-green);}
.dd-verr__col-title--pink{color:var(--color-pink);}
.dd-verr__col-title--orange{color:var(--color-orange);}
.dd-verr__col-title--yellow{color:var(--color-yellow);}
.dd-verr__col-title--ink{color:var(--color-ink);}
.dd-verr__col-title:hover{opacity:.8;}
.dd-verr__col-desc{font-family:var(--font-body);font-size:.75rem;color:var(--color-muted);line-height:1.4;margin:2px 0 0;}
.dd-verr__chevron{flex-shrink:0;color:var(--color-muted);opacity:.5;transition:opacity 120ms,transform 120ms;}
.dd-verr__products{display:flex;flex-direction:column;gap:2px;}
.dd-verr__product{display:flex;align-items:center;gap:12px;padding:8px 8px;border-radius:var(--radius-md);text-decoration:none;color:var(--color-ink);transition:background 120ms;}
.dd-verr__product:hover{background:var(--color-cream);}
.dd-verr__product:hover .dd-verr__chevron{opacity:.8;transform:translateX(2px);}
.dd-verr__product-img{width:64px;height:64px;object-fit:cover;border-radius:var(--radius-sm);flex-shrink:0;}
.dd-verr__product-info{flex:1;min-width:0;display:flex;flex-direction:column;gap:2px;}
.dd-verr__product-name-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.dd-verr__product-name-row strong{font-family:var(--font-body);font-size:.88rem;font-weight:700;color:var(--color-ink);}
.dd-verr__product-badge{background:var(--color-pink);color:#fff;font-family:var(--font-body);font-size:.6rem;font-weight:800;padding:2px 8px;border-radius:999px;white-space:nowrap;}
.dd-verr__product-desc{font-family:var(--font-body);font-size:.72rem;color:var(--color-muted);}
.dd-verr__extra-links{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:1px;padding-top:10px;border-top:1px solid var(--color-line);}
.dd-verr__extra-link{display:flex;align-items:center;gap:10px;padding:8px 8px;border-radius:var(--radius-sm);text-decoration:none;font-family:var(--font-body);font-size:.83rem;font-weight:600;color:var(--color-ink);transition:background 120ms;}
.dd-verr__extra-link:hover{background:var(--color-cream);}
.dd-verr__extra-link:hover .dd-verr__chevron{opacity:.8;transform:translateX(2px);}
.dd-verr__extra-link span{flex:1;}.dd-verr__extra-link .dd-verr__chevron{margin-left:auto;}
.dd-verr__col-links{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:1px;}
.dd-verr__col-link{display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:var(--radius-sm);text-decoration:none;font-family:var(--font-body);font-size:.83rem;font-weight:600;color:var(--color-ink);transition:background 120ms;}
.dd-verr__col-link:hover{background:var(--color-cream);}
.dd-verr__col-link:hover .dd-verr__chevron{opacity:.8;transform:translateX(2px);}
.dd-verr__col-link span{flex:1;}.dd-verr__col-link .dd-verr__chevron{margin-left:auto;}
.dd-verr__link-icon{width:28px;height:28px;min-width:28px;min-height:28px;border-radius:50%;flex-shrink:0;display:inline-flex;align-items:center;justify-content:center;}
.dd-verr__link-icon svg{width:12px;height:12px;}
.dd-verr__link-icon--green{background:#e8f5e2;color:var(--color-green);}
.dd-verr__link-icon--pink{background:#ffe0ee;color:var(--color-pink);}
.dd-verr__link-icon--orange{background:#fff0e4;color:var(--color-orange);}
.dd-verr__link-icon--yellow{background:#fffae0;color:var(--color-yellow);}
.dd-verr__link-icon--ink{background:var(--color-cream);color:var(--color-ink);}
.dd-verr__link-icon-sm--pink{background:#ffe0ee;color:var(--color-pink);}
.dd-verr__link-icon-sm--orange{background:#fff0e4;color:var(--color-orange);}
.dd-verr__link-icon-sm--yellow{background:#fffae0;color:var(--color-yellow);}
.dd-verr__col-cta{display:inline-flex;align-items:center;gap:5px;margin-top:12px;padding-top:10px;border-top:1px solid var(--color-line);font-family:var(--font-body);font-size:.82rem;font-weight:800;text-decoration:none;transition:gap 160ms;}
.dd-verr__col-cta:hover{gap:8px;}
.dd-verr__col-cta svg{width:13px;height:13px;}
.dd-verr__col-cta--green{color:var(--color-green);}
.dd-verr__col-cta--pink{color:var(--color-pink);}
.dd-verr__col-cta--orange{color:var(--color-orange);}
.dd-verr__col-cta--yellow{color:var(--color-yellow);}
.dd-verr__col-cta--ink{color:var(--color-ink);}
.dd-verr__mini-banner{display:flex;align-items:center;gap:8px;margin-top:auto;padding:10px 10px;border-radius:var(--radius-md);background:var(--color-cream);}
.dd-verr__mini-banner-text{flex:1;display:flex;flex-direction:column;gap:3px;}
.dd-verr__mini-banner-text strong{font-family:var(--font-body);font-size:.78rem;font-weight:800;color:var(--color-ink);}
.dd-verr__mini-banner-text span{font-family:var(--font-body);font-size:.72rem;color:var(--color-muted);}
.dd-verr__mini-banner-btn{width:26px;height:26px;border-radius:50%;background:var(--color-orange);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:4px;}
.dd-verr__mini-banner-btn svg{width:13px;height:13px;color:#fff;}
.dd-verr__mini-banner-img{width:64px;height:64px;object-fit:contain;flex-shrink:0;}
.dd-verr__banner{width:220px;flex-shrink:0;background:var(--color-cream);display:flex;flex-direction:column;overflow:hidden;border-left:1.5px solid var(--color-line);}
.dd-verr__banner-body{padding:18px 18px 0;display:flex;flex-direction:column;gap:6px;}
.dd-verr__banner-title{font-family:var(--font-heading);font-size:1.15rem;color:var(--color-ink);line-height:1.2;}
.dd-verr__banner-text{font-family:var(--font-body);font-size:.78rem;color:var(--color-muted);line-height:1.5;}
.dd-verr__banner-img-wrap{flex:1;overflow:hidden;min-height:160px;}
.dd-verr__banner-img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;}
.dd-verr__banner-cta-wrap{padding:14px 16px;flex-shrink:0;}
.dd-verr__banner-cta{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:12px 16px;background:var(--color-pink);color:#fff;border-radius:var(--radius-pill);font-family:var(--font-heading);font-size:.88rem;text-decoration:none;transition:background 160ms;}
.dd-verr__banner-cta:hover{background:#c4396a;}
.dd-verr__banner-cta svg{width:16px;height:16px;}

