{%- comment -%}
  sections/header.liquid — Kwispelbox KB-v3
  Announcement bar staat in header-group.json erboven.
  Desktop: logo | nav | iconen
  Per nav-item: rijk dropdown (2-koloms links + banner)
  Mobiel: hamburger | logo | cart → drawer
{%- endcomment -%}

{%- assign trust_blocks    = section.blocks | where: 'type', 'trust_item' -%}
{%- assign dropdown_blocks = section.blocks | where: 'type', 'dropdown_config' -%}

<div class="site-header__wrapper">

  <!-- ══ HOOFDBALK ════════════════════════════════════ -->
  <header class="site-header" role="banner">
    <div class="site-header__inner">

      <!-- Hamburger (mobiel) -->
      <button class="site-header__burger"
              aria-expanded="false"
              aria-controls="header-drawer"
              aria-label="Menu openen">
        {{- 'icon-menu.svg' | inline_asset_content -}}
      </button>

      <!-- Logo -->
      <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 400 }}"
            srcset="{{ section.settings.logo | image_url: width: 200 }} 200w,
                    {{ section.settings.logo | image_url: width: 400 }} 400w"
            sizes="{{ section.settings.logo_width }}px"
            alt="{{ section.settings.logo.alt | default: shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio | round }}"
            loading="eager" fetchpriority="high"
            class="site-header__logo-img">
        {%- else -%}
          <span class="site-header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <!-- Navigatie (desktop) -->
      {%- if section.settings.menu != blank -%}
        <nav class="site-header__nav" aria-label="Hoofdnavigatie">
          <ul class="site-header__chips" role="list">
            {%- for link in section.settings.menu.links -%}
              {%- assign link_index = forloop.index -%}

              {%- comment -%} Zoek dropdown config voor dit item {%- endcomment -%}
              {%- assign dropdown_cfg = nil -%}
              {%- for db in dropdown_blocks -%}
                {%- if db.settings.menu_item_index == link_index -%}
                  {%- assign dropdown_cfg = db -%}
                {%- endif -%}
              {%- endfor -%}

              {%- assign has_dropdown = false -%}
              {%- if dropdown_cfg != nil or link.links.size > 0 -%}
                {%- assign has_dropdown = true -%}
              {%- endif -%}

              <li class="site-header__chip-item{% if has_dropdown %} site-header__chip-item--has-dropdown{% endif %}"
                  data-nav-item>

                <a href="{{ link.url }}"
                   class="site-header__chip"
                   style="--chip-color: {%- if dropdown_cfg -%}var(--color-{{ dropdown_cfg.settings.accent_color }}){%- else -%}var(--color-ink){%- endif -%}"
                   {% if link.active %}aria-current="page"{% endif %}
                   {% if has_dropdown %}aria-haspopup="true" aria-expanded="false" data-nav-trigger{% endif %}>
                  {{ link.title }}
                  {%- if has_dropdown -%}
                    <span class="site-header__chip-chevron" aria-hidden="true">
                      {{- 'icon-chevron-down.svg' | inline_asset_content -}}
                    </span>
                  {%- endif -%}
                </a>

                {%- if has_dropdown -%}
                  <div class="site-header__dropdown" data-nav-dropdown>
                    <div class="site-header__dropdown-inner">

                      <!-- Links kolom (2-koloms grid) -->
                      <div class="site-header__dropdown-links">
                        {%- assign sub_links = nil -%}
                        {%- if dropdown_cfg != nil and dropdown_cfg.settings.link_list != blank -%}
                          {%- assign sub_links = dropdown_cfg.settings.link_list.links -%}
                        {%- elsif link.links.size > 0 -%}
                          {%- assign sub_links = link.links -%}
                        {%- endif -%}

                        {%- if sub_links != nil -%}
                          <ul class="site-header__dropdown-grid" role="list">
                            {%- for child in sub_links -%}
                              <li>
                                <a href="{{ child.url }}"
                                   class="site-header__dropdown-item"
                                   {% if child.active %}aria-current="page"{% endif %}>
                                  <span class="site-header__dropdown-item-icon
                                    {%- if dropdown_cfg -%} site-header__dropdown-item-icon--{{ dropdown_cfg.settings.accent_color }}{%- endif -%}"
                                    aria-hidden="true">
                                    {{- 'icon-paw.svg' | inline_asset_content -}}
                                  </span>
                                  <span class="site-header__dropdown-item-text">
                                    <strong>{{ child.title }}</strong>
                                  </span>
                                  <svg class="site-header__dropdown-item-arrow" width="14" height="14"
                                       viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                       stroke-width="2" stroke-linecap="round" aria-hidden="true">
                                    <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                                  </svg>
                                </a>
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}

                        {%- if dropdown_cfg != nil and dropdown_cfg.settings.view_all_label != blank -%}
                          <a href="{{ dropdown_cfg.settings.view_all_url | default: link.url }}"
                             class="site-header__dropdown-view-all
                             {%- if dropdown_cfg -%} site-header__dropdown-view-all--{{ dropdown_cfg.settings.accent_color }}{%- endif -%}">
                            {{ dropdown_cfg.settings.view_all_label }}
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                            </svg>
                          </a>
                        {%- endif -%}
                      </div>

                      <!-- Banner rechts -->
                      {%- if dropdown_cfg != nil and dropdown_cfg.settings.banner_title != blank -%}
                        <div class="site-header__dropdown-banner" {{ dropdown_cfg.shopify_attributes }}>
                          {%- if dropdown_cfg.settings.banner_image != blank -%}
                            <div class="site-header__dropdown-banner-img-wrap">
                              <img
                                src="{{ dropdown_cfg.settings.banner_image | image_url: width: 600 }}"
                                alt="{{ dropdown_cfg.settings.banner_image.alt | default: dropdown_cfg.settings.banner_title | escape }}"
                                width="600" height="400"
                                loading="lazy"
                                class="site-header__dropdown-banner-img">
                              {%- if dropdown_cfg.settings.banner_badge != blank -%}
                                <span class="site-header__dropdown-banner-badge">
                                  {{ dropdown_cfg.settings.banner_badge }}
                                </span>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                          <div class="site-header__dropdown-banner-body">
                            <strong class="site-header__dropdown-banner-title">
                              {{ dropdown_cfg.settings.banner_title }}
                            </strong>
                            {%- if dropdown_cfg.settings.banner_text != blank -%}
                              <span class="site-header__dropdown-banner-text">
                                {{ dropdown_cfg.settings.banner_text }}
                              </span>
                            {%- endif -%}
                            {%- if dropdown_cfg.settings.banner_cta_label != blank -%}
                              <a href="{{ dropdown_cfg.settings.banner_cta_url | default: link.url }}"
                                 class="site-header__dropdown-banner-cta">
                                {{ dropdown_cfg.settings.banner_cta_label }}
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                                </svg>
                              </a>
                            {%- endif -%}
                          </div>
                        </div>
                      {%- endif -%}

                    </div>
                  </div>
                {%- endif -%}

              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      <!-- Iconen: zoek, account, cart -->
      <div class="site-header__actions">

        {%- if section.settings.show_search -%}
          <button class="site-header__icon-btn"
                  aria-expanded="false"
                  aria-controls="header-search-panel"
                  aria-label="Zoeken openen"
                  data-search-toggle>
            {{- 'icon-search.svg' | inline_asset_content -}}
          </button>
        {%- endif -%}

        {%- if shop.customer_accounts_enabled -%}
          <shopify-account menu="{{ section.settings.customer_account_menu }}"
                           class="site-header__account">
            <a href="{{ routes.account_url }}" class="site-header__icon-btn">
              {{- 'icon-account.svg' | inline_asset_content -}}
            </a>
          </shopify-account>
        {%- endif -%}

        <a href="{{ routes.cart_url }}"
           class="site-header__icon-btn site-header__cart-btn"
           aria-label="Winkelwagen, {{ cart.item_count }} items">
          {{- 'icon-cart.svg' | inline_asset_content -}}
          {%- if cart.item_count > 0 -%}
            <span class="site-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>

      </div>
    </div>
  </header>

  <!-- ══ ZOEKPANEEL ═══════════════════════════════════ -->
  {%- if section.settings.show_search -%}
    <div class="site-header__search-panel" id="header-search-panel"
         aria-hidden="true" data-search-panel>
      <div class="site-header__search-wrap">
        <form action="{{ routes.search_url }}" method="get" role="search"
              class="site-header__search-form" data-search-form>
          <input type="hidden" name="type" value="product">
          <label for="header-search-input" class="site-header__sr-only">Zoeken</label>
          <div class="site-header__search-field">
            <span class="site-header__search-icon" aria-hidden="true">
              {{- 'icon-search.svg' | inline_asset_content -}}
            </span>
            <input type="search" id="header-search-input" name="q"
              class="site-header__search-input"
              placeholder="{{ section.settings.search_placeholder }}"
              autocomplete="off" autocorrect="off" spellcheck="false"
              data-search-input aria-autocomplete="list" aria-controls="search-results">
            <button type="button" class="site-header__search-clear"
                    aria-label="Wissen" hidden data-search-clear>
              {{- 'icon-close.svg' | inline_asset_content -}}
            </button>
          </div>
          <button type="submit" class="site-header__search-btn">
            {{ section.settings.search_button_label }}
          </button>
          <div class="site-header__search-results" id="search-results"
               role="listbox" hidden data-search-results></div>
        </form>
      </div>
    </div>
  {%- endif -%}

  <!-- ══ TRUST BAR ════════════════════════════════════ -->
  {%- if trust_blocks.size > 0 -%}
    <div class="site-header__trust-bar">
      <div class="site-header__trust-inner">
        {%- for block in trust_blocks -%}
          <div class="site-header__trust-item" {{ block.shopify_attributes }}>
            {%- if block.settings.url != blank -%}<a href="{{ block.settings.url }}" class="site-header__trust-link">
            {%- else -%}<span class="site-header__trust-link">
            {%- endif -%}
              <span class="site-header__trust-icon" aria-hidden="true">
                {{- block.settings.icon | inline_asset_content -}}
              </span>
              <span class="site-header__trust-text">
                <strong>{{ block.settings.title }}</strong>
                {%- if block.settings.subtitle != blank -%}
                  <span>{{ block.settings.subtitle }}</span>
                {%- endif -%}
              </span>
            {%- if block.settings.url != blank -%}</a>{%- else -%}</span>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>

<!-- ══ OVERLAY ══════════════════════════════════════════ -->
<div class="site-header__overlay" id="nav-overlay" aria-hidden="true" data-nav-overlay></div>

<!-- ══ MOBIEL DRAWER ════════════════════════════════════ -->
<div class="header-drawer" id="header-drawer" role="dialog"
     aria-modal="true" aria-label="Navigatiemenu" aria-hidden="true">

  <div class="header-drawer__header">
    <span class="header-drawer__title">Menu</span>
    <button class="header-drawer__close" aria-label="Sluiten" data-drawer-close>
      {{- 'icon-close.svg' | inline_asset_content -}}
    </button>
  </div>

  <form action="{{ routes.search_url }}" method="get" role="search"
        class="header-drawer__search">
    <input type="hidden" name="type" value="product">
    <label for="drawer-search" class="site-header__sr-only">Zoeken</label>
    <div class="header-drawer__search-field">
      <span aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
      <input type="search" id="drawer-search" name="q"
        class="header-drawer__search-input"
        placeholder="{{ section.settings.search_placeholder }}"
        autocomplete="off">
    </div>
    <button type="submit" class="header-drawer__search-btn">
      {{ section.settings.search_button_label }}
    </button>
  </form>

  <nav aria-label="Mobiel menu">
    <ul class="header-drawer__nav" role="list">
      {%- for link in section.settings.menu.links -%}
        <li class="header-drawer__nav-item{% if link.links.size > 0 %} header-drawer__nav-item--has-sub{% endif %}">
          <div class="header-drawer__nav-row">
            <a href="{{ link.url }}" class="header-drawer__nav-link"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
            {%- if link.links.size > 0 -%}
              <button class="header-drawer__sub-toggle"
                      aria-expanded="false"
                      aria-label="{{ link.title }} submenu">
                {{- 'icon-chevron-down.svg' | inline_asset_content -}}
              </button>
            {%- endif -%}
          </div>
          {%- if link.links.size > 0 -%}
            <ul class="header-drawer__sub-nav" role="list" hidden>
              {%- for child in link.links -%}
                <li>
                  <a href="{{ child.url }}" class="header-drawer__sub-link"
                     {% if child.active %}aria-current="page"{% endif %}>
                    {{ child.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  {%- if shop.customer_accounts_enabled -%}
    <div class="header-drawer__footer">
      <a href="{{ routes.account_url }}" class="header-drawer__account-link">
        {{- 'icon-account.svg' | inline_asset_content -}}
        {%- if customer -%}Mijn account{%- else -%}{{ section.settings.account_label }}{%- endif -%}
      </a>
    </div>
  {%- endif -%}

</div>
<div class="header-drawer__overlay" id="header-overlay"
     aria-hidden="true" data-drawer-overlay></div>

{% stylesheet %}
/* ── Helpers ───────────────────────────────────────────── */
.site-header__sr-only{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;}

/* ── Wrapper ───────────────────────────────────────────── */
.site-header__wrapper{position:sticky;top:0;z-index:100;background:#fff;}

/* ── Hoofdbalk ─────────────────────────────────────────── */
.site-header{background:#fff;border-bottom:1.5px solid var(--color-line);}
.site-header__inner{max-width:var(--page-width);margin:0 auto;padding:0 var(--page-margin);height:72px;display:flex;align-items:center;gap:20px;}

/* ── Hamburger ─────────────────────────────────────────── */
.site-header__burger{display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;padding:6px;color:var(--color-ink);flex-shrink:0;}
.site-header__burger svg{width:24px;height:24px;}
@media(min-width:990px){.site-header__burger{display:none;}}

/* ── Logo ──────────────────────────────────────────────── */
.site-header__logo{display:flex;align-items:center;text-decoration:none;flex-shrink:0;}
.site-header__logo-img{height:auto;max-height:52px;width:auto;display:block;}
.site-header__logo-text{font-family:var(--font-heading);font-size:1.6rem;color:var(--color-ink);white-space:nowrap;}

/* ── Navigatie ─────────────────────────────────────────── */
.site-header__nav{flex:1;display:flex;justify-content:center;}
@media(max-width:989px){.site-header__nav{display:none;}}
.site-header__chips{display:flex;align-items:center;gap:2px;list-style:none;margin:0;padding:0;}
.site-header__chip-item{position:static;}

.site-header__chip{
  display:inline-flex;align-items:center;gap:5px;
  padding:8px 14px;border-radius:var(--radius-pill);
  font-family:var(--font-body);font-size:.88rem;font-weight:700;
  text-decoration:none;white-space:nowrap;
  color:var(--color-ink);background:none;border:none;cursor:pointer;
  transition:background 160ms,color 160ms;
}
.site-header__chip:hover,.site-header__chip[aria-current="page"]{background:var(--color-cream);}
.site-header__chip[aria-expanded="true"]{background:var(--color-cream);color:var(--chip-color,var(--color-ink));}

.site-header__chip-chevron{display:inline-flex;align-items:center;margin-left:2px;transition:transform 200ms ease;}
.site-header__chip-chevron svg{width:13px;height:13px;}
.site-header__chip[aria-expanded="true"] .site-header__chip-chevron{transform:rotate(180deg);}

/* ── Dropdown ──────────────────────────────────────────── */
.site-header__dropdown{
  position:fixed;
  left:0;right:0;
  top:var(--header-bottom, 72px);
  background:#fff;
  border-bottom:1.5px solid var(--color-line);
  box-shadow:0 20px 60px rgba(61,34,9,.1);
  z-index:99;
  opacity:0;visibility:hidden;
  transform:translateY(-8px);
  transition:opacity 200ms ease,visibility 200ms ease,transform 200ms ease;
  pointer-events:none;
}
.site-header__dropdown[data-open]{
  opacity:1;visibility:visible;transform:translateY(0);pointer-events:auto;
}
.site-header__dropdown-inner{
  max-width:var(--page-width);margin:0 auto;
  padding:28px var(--page-margin) 32px;
  display:flex;gap:0;align-items:stretch;
}

/* Link-kolom (links) */
.site-header__dropdown-links{flex:1;min-width:0;padding-right:28px;display:flex;flex-direction:column;}
.site-header__dropdown-grid{
  flex:1;
  list-style:none;margin:0;padding:0;
  display:grid;grid-template-columns:1fr 1fr;
  gap:2px;align-content:start;
}
.site-header__dropdown-item{
  display:flex;align-items:center;gap:12px;
  padding:10px 12px;border-radius:var(--radius-md);
  text-decoration:none;color:var(--color-ink);
  transition:background 120ms;
}
.site-header__dropdown-item:hover{background:var(--color-cream);}
.site-header__dropdown-item:hover .site-header__dropdown-item-arrow{opacity:1;transform:translateX(3px);}

/* Icoon cirkel per sub-item */
.site-header__dropdown-item-icon{
  width:40px;height:40px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;background:var(--color-cream);color:var(--color-muted);
}
.site-header__dropdown-item-icon svg{width:18px;height:18px;}
.site-header__dropdown-item-icon--green {background:#e8f5e2;color:var(--color-green);}
.site-header__dropdown-item-icon--pink  {background:#ffe0ee;color:var(--color-pink);}
.site-header__dropdown-item-icon--orange{background:#fff0e4;color:var(--color-orange);}
.site-header__dropdown-item-icon--yellow{background:#fffae0;color:var(--color-yellow);}
.site-header__dropdown-item-icon--ink   {background:#f5efe6;color:var(--color-ink);}

.site-header__dropdown-item-text{flex:1;min-width:0;}
.site-header__dropdown-item-text strong{display:block;font-family:var(--font-body);font-size:.9rem;font-weight:700;color:var(--color-ink);}
.site-header__dropdown-item-arrow{width:13px;height:13px;flex-shrink:0;color:var(--color-muted);opacity:0;transition:opacity 120ms,transform 120ms;}

/* "Bekijk alle" link */
.site-header__dropdown-view-all{
  display:inline-flex;align-items:center;gap:5px;
  margin-top:16px;padding-top:14px;
  border-top:1px solid var(--color-line);
  font-family:var(--font-body);font-size:.85rem;font-weight:800;
  text-decoration:none;transition:gap 160ms;
  color:var(--color-ink);
}
.site-header__dropdown-view-all:hover{gap:8px;}
.site-header__dropdown-view-all svg{width:14px;height:14px;}
.site-header__dropdown-view-all--green {color:var(--color-green);}
.site-header__dropdown-view-all--pink  {color:var(--color-pink);}
.site-header__dropdown-view-all--orange{color:var(--color-orange);}
.site-header__dropdown-view-all--yellow{color:var(--color-yellow);}

/* Banner rechts */
.site-header__dropdown-banner{
  width:280px;flex-shrink:0;
  border-left:1.5px solid var(--color-line);
  padding-left:28px;
  display:flex;flex-direction:column;
}
.site-header__dropdown-banner-img-wrap{position:relative;border-radius:var(--radius-lg);overflow:hidden;flex-shrink:0;}
.site-header__dropdown-banner-img{width:100%;height:200px;object-fit:cover;display:block;}
.site-header__dropdown-banner-badge{
  position:absolute;top:12px;left:12px;
  background:var(--color-green);color:#fff;
  font-family:var(--font-heading);font-size:.75rem;
  padding:4px 12px;border-radius:var(--radius-pill);
}
.site-header__dropdown-banner-body{
  padding:14px 0 0;
  display:flex;flex-direction:column;gap:6px;flex:1;
}
.site-header__dropdown-banner-title{
  font-family:var(--font-heading);font-size:1.15rem;color:var(--color-ink);line-height:1.2;
}
.site-header__dropdown-banner-text{
  font-family:var(--font-body);font-size:.82rem;color:var(--color-muted);line-height:1.5;
}
.site-header__dropdown-banner-cta{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  margin-top:10px;padding:11px 20px;
  background:var(--color-pink);color:#fff;
  font-family:var(--font-heading);font-size:.88rem;
  text-decoration:none;border-radius:var(--radius-pill);
  transition:background 160ms,transform 160ms;
  border:none;cursor:pointer;
}
.site-header__dropdown-banner-cta:hover{background:#c4396a;transform:translateY(-1px);}
.site-header__dropdown-banner-cta svg{width:15px;height:15px;}

/* ── Iconen rechts ─────────────────────────────────────── */
.site-header__actions{display:flex;align-items:center;gap:4px;flex-shrink:0;}
.site-header__account{display:flex;}
.site-header__icon-btn{
  display:flex;align-items:center;justify-content:center;position:relative;
  background:none;border:none;cursor:pointer;
  color:var(--color-ink);padding:8px;border-radius:var(--radius-sm);
  text-decoration:none;transition:background 160ms;
}
.site-header__icon-btn:hover{background:var(--color-cream);}
.site-header__icon-btn svg{width:22px;height:22px;}
.site-header__cart-count{
  position:absolute;top:-4px;right:-4px;
  background:var(--color-pink);color:#fff;
  font-family:var(--font-body);font-size:.6rem;font-weight:800;
  min-width:18px;height:18px;padding:0 4px;border-radius:999px;
  display:flex;align-items:center;justify-content:center;border:2px solid #fff;
}

/* ── Zoekpaneel ────────────────────────────────────────── */
.site-header__search-panel{
  background:#fff;border-bottom:1.5px solid var(--color-line);
  max-height:0;overflow:hidden;
  transition:max-height 280ms cubic-bezier(.4,0,.2,1);
}
.site-header__search-panel[aria-hidden="false"]{max-height:100px;}
@media(max-width:989px){.site-header__search-panel{display:none;}}
.site-header__search-wrap{
  max-width:var(--page-width);margin:0 auto;
  padding:12px var(--page-margin);
  display:flex;justify-content:center;
  position:relative;
}
.site-header__search-form{display:flex;align-items:center;gap:8px;width:100%;max-width:600px;position:relative;}
.site-header__search-field{
  flex:1;display:flex;align-items:center;
  background:var(--color-cream);border-radius:var(--radius-pill);
  border:1.5px solid var(--color-line);padding:0 14px;gap:8px;
  transition:border-color 160ms;
}
.site-header__search-field:focus-within{border-color:var(--color-ink);background:#fff;}
.site-header__search-icon{display:flex;align-items:center;flex-shrink:0;color:var(--color-muted);}
.site-header__search-icon svg{width:16px;height:16px;}
.site-header__search-input{flex:1;height:44px;background:none;border:none;outline:none;font-family:var(--font-body);font-size:.9rem;color:var(--color-ink);min-width:0;}
.site-header__search-input::placeholder{color:var(--color-muted);}
.site-header__search-clear{display:flex;align-items:center;background:none;border:none;cursor:pointer;padding:2px;color:var(--color-muted);}
.site-header__search-clear svg{width:14px;height:14px;}
.site-header__search-btn{height:44px;padding:0 22px;background:var(--color-ink);color:#fff;border:none;border-radius:var(--radius-pill);font-family:var(--font-heading);font-size:.9rem;cursor:pointer;flex-shrink:0;transition:background 160ms;}
.site-header__search-btn:hover{background:#5a3210;}
.site-header__search-results{position:absolute;top:calc(100% + 8px);left:0;right:0;background:#fff;border:1.5px solid var(--color-line);border-radius:var(--radius-md);box-shadow:0 8px 24px rgba(0,0,0,.08);overflow:hidden;z-index:200;}
.search-result-item{display:flex;align-items:center;gap:12px;padding:10px 16px;text-decoration:none;color:var(--color-ink);border-bottom:1px solid var(--color-line);transition:background 120ms;}
.search-result-item:last-child{border-bottom:none;}
.search-result-item:hover,.search-result-item[aria-selected="true"]{background:var(--color-cream);}
.search-result-item__img{width:44px;height:44px;object-fit:cover;border-radius:var(--radius-sm);flex-shrink:0;background:var(--color-cream);}
.search-result-item__title{font-family:var(--font-body);font-size:.88rem;font-weight:700;color:var(--color-ink);}
.search-result-item__price{font-family:var(--font-body);font-size:.82rem;color:var(--color-muted);margin-top:2px;}
.search-result-item__all{display:block;padding:10px 16px;font-family:var(--font-body);font-size:.85rem;font-weight:700;color:var(--color-ink);text-decoration:none;text-align:center;border-top:1px solid var(--color-line);}
.search-result-item__all:hover{background:var(--color-cream);}

/* ── Trust bar ─────────────────────────────────────────── */
.site-header__trust-bar{background:#fff;border-top:1.5px solid var(--color-line);}
@media(max-width:989px){.site-header__trust-bar{display:none;}}
.site-header__trust-inner{max-width:var(--page-width);margin:0 auto;padding:0 var(--page-margin);height:44px;display:flex;align-items:center;justify-content:center;}
.site-header__trust-item{display:flex;}
.site-header__trust-link{display:inline-flex;align-items:center;gap:6px;padding:5px 16px;font-family:var(--font-body);font-size:.78rem;font-weight:700;color:var(--color-body);text-decoration:none;border-right:1px solid var(--color-line);transition:color 160ms;white-space:nowrap;}
.site-header__trust-item:last-child .site-header__trust-link{border-right:none;}
.site-header__trust-link:hover{color:var(--color-ink);}
.site-header__trust-icon{display:flex;align-items:center;flex-shrink:0;color:var(--color-muted);}
.site-header__trust-icon svg{width:14px;height:14px;}
.site-header__trust-text strong{font-family:var(--font-body);font-size:.78rem;font-weight:800;color:var(--color-ink);}
.site-header__trust-text span{font-family:var(--font-body);font-size:.7rem;color:var(--color-muted);}

/* ── Overlay ───────────────────────────────────────────── */
.site-header__overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:98;opacity:0;visibility:hidden;transition:opacity 200ms,visibility 200ms;}
.site-header__overlay[aria-hidden="false"]{opacity:1;visibility:visible;}

/* ══ MOBIEL DRAWER ══════════════════════════════════════ */
.header-drawer{position:fixed;top:0;left:0;bottom:0;width:min(320px,85vw);background:#fff;z-index:300;overflow-y:auto;overscroll-behavior:contain;transform:translateX(-100%);transition:transform 280ms cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;}
.header-drawer[aria-hidden="false"]{transform:translateX(0);}
.header-drawer__header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--color-line);flex-shrink:0;}
.header-drawer__title{font-family:var(--font-heading);font-size:1.1rem;color:var(--color-ink);}
.header-drawer__close{display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;padding:4px;color:var(--color-ink);}
.header-drawer__close svg{width:22px;height:22px;}
.header-drawer__search{padding:16px 20px;border-bottom:1px solid var(--color-line);display:flex;gap:8px;flex-shrink:0;}
.header-drawer__search-field{flex:1;display:flex;align-items:center;gap:8px;background:var(--color-cream);border-radius:var(--radius-pill);border:1.5px solid var(--color-line);padding:0 12px;}
.header-drawer__search-field svg{width:16px;height:16px;color:var(--color-muted);flex-shrink:0;}
.header-drawer__search-input{flex:1;height:40px;background:none;border:none;outline:none;font-family:var(--font-body);font-size:.9rem;color:var(--color-ink);min-width:0;}
.header-drawer__search-btn{height:40px;padding:0 16px;background:var(--color-ink);color:#fff;border:none;border-radius:var(--radius-pill);font-family:var(--font-heading);font-size:.85rem;cursor:pointer;flex-shrink:0;}
.header-drawer__nav{list-style:none;margin:0;padding:8px 0;flex:1;}
.header-drawer__nav-item{border-bottom:1px solid var(--color-line);}
.header-drawer__nav-row{display:flex;align-items:center;}
.header-drawer__nav-link{flex:1;padding:14px 20px;text-decoration:none;font-family:var(--font-body);font-size:1rem;font-weight:700;color:var(--color-ink);transition:color 120ms;}
.header-drawer__nav-link:hover,.header-drawer__nav-link[aria-current="page"]{color:var(--color-pink);}
.header-drawer__sub-toggle{background:none;border:none;cursor:pointer;padding:14px 16px;color:var(--color-muted);display:flex;align-items:center;transition:transform 200ms;}
.header-drawer__sub-toggle svg{width:18px;height:18px;}
.header-drawer__sub-toggle[aria-expanded="true"]{transform:rotate(180deg);}
.header-drawer__sub-nav{list-style:none;margin:0;padding:0;background:var(--color-cream);}
.header-drawer__sub-link{display:block;padding:10px 20px 10px 32px;text-decoration:none;font-family:var(--font-body);font-size:.88rem;color:var(--color-body);border-top:1px solid var(--color-line);transition:color 120ms;}
.header-drawer__sub-link:hover{color:var(--color-pink);}
.header-drawer__footer{padding:16px 20px;border-top:1px solid var(--color-line);flex-shrink:0;}
.header-drawer__account-link{display:inline-flex;align-items:center;gap:8px;text-decoration:none;font-family:var(--font-body);font-size:.9rem;font-weight:700;color:var(--color-ink);}
.header-drawer__account-link svg{width:18px;height:18px;}
.header-drawer__overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:299;opacity:0;visibility:hidden;transition:opacity 280ms,visibility 280ms;}
.header-drawer__overlay[aria-hidden="false"]{opacity:1;visibility:visible;}
{% endstylesheet %}

{% javascript %}
(function () {
  'use strict';

  var wrapper   = document.querySelector('.site-header__wrapper');
  var overlay   = document.getElementById('nav-overlay');
  var dropdowns = document.querySelectorAll('[data-nav-dropdown]');
  var triggers  = document.querySelectorAll('[data-nav-trigger]');
  var openTimer = null;
  var closeTimer = null;
  var activeDropdown = null;

  /* Bereken en sla header-hoogte op voor dropdown positionering */
  function updateHeaderBottom() {
    if (wrapper) {
      var h = wrapper.getBoundingClientRect().bottom;
      document.querySelectorAll('.site-header__dropdown').forEach(function (d) {
        d.style.top = h + 'px';
      });
    }
  }
  updateHeaderBottom();
  window.addEventListener('resize', updateHeaderBottom);

  function openDropdown(dropdown, trigger) {
    clearTimeout(closeTimer);
    if (activeDropdown && activeDropdown !== dropdown) {
      closeDropdownEl(activeDropdown);
    }
    dropdown.setAttribute('data-open', '');
    trigger && trigger.setAttribute('aria-expanded', 'true');
    overlay && overlay.setAttribute('aria-hidden', 'false');
    activeDropdown = dropdown;
  }

  function closeDropdownEl(dropdown) {
    dropdown.removeAttribute('data-open');
    var trigger = dropdown.closest('.site-header__chip-item').querySelector('[data-nav-trigger]');
    trigger && trigger.setAttribute('aria-expanded', 'false');
  }

  function closeAll() {
    closeTimer = setTimeout(function () {
      dropdowns.forEach(closeDropdownEl);
      overlay && overlay.setAttribute('aria-hidden', 'true');
      activeDropdown = null;
    }, 100);
  }

  triggers.forEach(function (trigger) {
    var item     = trigger.closest('.site-header__chip-item');
    var dropdown = item && item.querySelector('[data-nav-dropdown]');
    if (!dropdown) return;

    item.addEventListener('mouseenter', function () {
      clearTimeout(closeTimer);
      openTimer = setTimeout(function () { openDropdown(dropdown, trigger); }, 80);
    });
    item.addEventListener('mouseleave', function () {
      clearTimeout(openTimer);
      closeAll();
    });

    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        var open = trigger.getAttribute('aria-expanded') === 'true';
        if (open) { closeAll(); } else { openDropdown(dropdown, trigger); }
      }
      if (e.key === 'Escape') { closeAll(); trigger.focus(); }
    });
  });

  dropdowns.forEach(function (dropdown) {
    dropdown.addEventListener('mouseenter', function () { clearTimeout(closeTimer); });
    dropdown.addEventListener('mouseleave', closeAll);
  });

  overlay && overlay.addEventListener('click', closeAll);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && activeDropdown) { closeAll(); }
  });

  /* ── Zoekpaneel toggle ─────────────────────────────────── */
  var searchToggle = document.querySelector('[data-search-toggle]');
  var searchPanel  = document.getElementById('header-search-panel');
  var searchInput  = document.querySelector('[data-search-input]');
  var searchResults = document.querySelector('[data-search-results]');
  var searchClear  = document.querySelector('[data-search-clear]');
  var searchForm   = document.querySelector('[data-search-form]');

  if (searchToggle && searchPanel) {
    searchToggle.addEventListener('click', function () {
      var open = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', !open);
      searchPanel.setAttribute('aria-hidden', open);
      if (!open && searchInput) setTimeout(function () { searchInput.focus(); }, 300);
    });
  }

  /* Predictive search */
  if (searchInput && searchResults) {
    var debounceTimer = null;
    function money(cents) { return '\u20ac' + (cents / 100).toFixed(2).replace('.', ','); }
    function renderResults(results, query) {
      if (!results.length) { searchResults.hidden = true; return; }
      var html = results.map(function (item) {
        var img = item.image ? '<img src="' + item.image + '" alt="" class="search-result-item__img" width="44" height="44" loading="lazy">' : '<div class="search-result-item__img"></div>';
        var price = item.price ? '<span class="search-result-item__price">' + money(item.price) + '</span>' : '';
        return '<a href="' + item.url + '" class="search-result-item" role="option">' + img + '<span><span class="search-result-item__title">' + item.title + '</span>' + price + '</span></a>';
      }).join('');
      html += '<a href="/search?type=product&q=' + encodeURIComponent(query) + '" class="search-result-item__all">Alle resultaten &rarr;</a>';
      searchResults.innerHTML = html;
      searchResults.hidden = false;
    }
    function fetchSuggestions(q) {
      if (q.length < 2) { searchResults.hidden = true; return; }
      fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=5&resources[fields]=title,handle,image,price')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          var products = (data.resources && data.resources.results && data.resources.results.products) || [];
          renderResults(products.map(function (p) { return { title: p.title, url: p.url, image: p.image ? p.image.src : null, price: p.price }; }), q);
        }).catch(function () { searchResults.hidden = true; });
    }
    searchInput.addEventListener('input', function () {
      var q = this.value.trim();
      searchClear && (searchClear.hidden = q.length === 0);
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function () { fetchSuggestions(q); }, 220);
    });
    searchClear && searchClear.addEventListener('click', function () {
      searchInput.value = ''; searchInput.focus(); this.hidden = true; searchResults.hidden = true;
    });
    document.addEventListener('click', function (e) {
      if (searchForm && !searchForm.contains(e.target) && searchToggle && !searchToggle.contains(e.target)) searchResults.hidden = true;
    });
  }

  /* ── Mobiel drawer ─────────────────────────────────────── */
  var drawer   = document.getElementById('header-drawer');
  var drawerOverlay = document.getElementById('header-overlay');
  var burger   = document.querySelector('.site-header__burger');
  var closeBtn = document.querySelector('[data-drawer-close]');

  function openDrawer() {
    if (!drawer) return;
    drawer.setAttribute('aria-hidden', 'false');
    drawerOverlay && drawerOverlay.setAttribute('aria-hidden', 'false');
    burger && burger.setAttribute('aria-expanded', 'true');
    document.documentElement.style.overflow = 'hidden';
    closeBtn && closeBtn.focus();
  }
  function closeDrawer() {
    if (!drawer) return;
    drawer.setAttribute('aria-hidden', 'true');
    drawerOverlay && drawerOverlay.setAttribute('aria-hidden', 'true');
    burger && burger.setAttribute('aria-expanded', 'false');
    document.documentElement.style.overflow = '';
    burger && burger.focus();
  }
  burger   && burger.addEventListener('click', openDrawer);
  closeBtn && closeBtn.addEventListener('click', closeDrawer);
  drawerOverlay && drawerOverlay.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer && drawer.getAttribute('aria-hidden') === 'false') closeDrawer();
  });

  document.querySelectorAll('.header-drawer__sub-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var expanded = this.getAttribute('aria-expanded') === 'true';
      var sub = this.closest('.header-drawer__nav-item').querySelector('.header-drawer__sub-nav');
      this.setAttribute('aria-expanded', !expanded);
      if (sub) sub.hidden = expanded;
    });
  });

}());
{% endjavascript %}

